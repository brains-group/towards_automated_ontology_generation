### Adding New Classes: Cl_DeathBenefitEvent, Cl_ProofOfDeathEvent, Cl_PaymentOfProceedsEvent, Cl_InterestOnDeathBenefitEvent, Cl_CertifiedDeathCertificate, Cl_ContingentBeneficiaryRole, Cl_InterestRate ###
:Cl_DeathBenefitEvent a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Death Benefit Event" ;
    rdfs:comment "A discrete event in which the insurer disburses the death benefit to the designated beneficiary upon the insured's death while the policy is in force and before expiry." .

:Cl_ProofOfDeathEvent a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Proof of Death Event" ;
    rdfs:comment "The event requiring submission of documentation to verify the insured’s death, including a certified death certificate and additional reasonable requests by the company." .

:Cl_PaymentOfProceedsEvent a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Payment of Proceeds Event" ;
    rdfs:comment "The event in which the death benefit proceeds are disbursed to the beneficiary or estate, typically in a lump sum unless otherwise elected." .

:Cl_InterestOnDeathBenefitEvent a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Interest on Death Benefit Event" ;
    rdfs:comment "The event in which interest accrues on the death benefit from the date of death to the date of payment, at a rate not less than required by state law." .

:Cl_CertifiedDeathCertificate a owl:Class ;
    rdfs:subClassOf :Cl_EvidenceOfInsurability ;
    rdfs:label "Certified Death Certificate" ;
    rdfs:comment "A document issued by a government authority certifying the death of an individual." .

:Cl_ContingentBeneficiaryRole a owl:Class ;
    rdfs:subClassOf :Cl_BeneficiaryRole ;
    rdfs:label "Contingent Beneficiary Role" ;
    rdfs:comment "A role for a beneficiary who receives the death benefit if the primary beneficiary does not survive the insured." .

:Cl_InterestRate a owl:Class ;
    rdfs:subClassOf :Cl_MonetaryAmount ;
    rdfs:label "Interest Rate" ;
    rdfs:comment "The rate applied to the death benefit for interest accrual, expressed as a decimal fraction." .

### Adding New Object Properties for Reification: hasDeathBenefitEvent, hasProofOfDeathEvent, hasPaymentOfProceedsEvent, hasInterestOnDeathBenefitEvent, hasCertifiedDeathCertificate, hasContingentBeneficiary, hasInterestRateReification, hasDeduction, hasNetPayout ###
:hasDeathBenefitEvent a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_DeathBenefitEvent ;
    rdfs:label "has Death Benefit Event" ;
    rdfs:comment "Links a policy to the event when the death benefit is paid to the beneficiary." .

:hasProofOfDeathEvent a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_ProofOfDeathEvent ;
    rdfs:label "has Proof of Death Event" ;
    rdfs:comment "Links a policy to the event requiring proof of the insured's death." .

:hasPaymentOfProceedsEvent a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PaymentOfProceedsEvent ;
    rdfs:label "has Payment of Proceeds Event" ;
    rdfs:comment "Links a policy to the event when the death benefit proceeds are disbursed." .

:hasInterestOnDeathBenefitEvent a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_InterestOnDeathBenefitEvent ;
    rdfs:label "has Interest on Death Benefit Event" ;
    rdfs:comment "Links a policy to the event when interest accrues on the death benefit." .

:hasCertifiedDeathCertificate a owl:ObjectProperty ;
    rdfs:domain :Cl_ProofOfDeathEvent ;
    rdfs:range :Cl_CertifiedDeathCertificate ;
    rdfs:label "has Certified Death Certificate" ;
    rdfs:comment "Links a proof of death event to the required certified death certificate." .

:hasContingentBeneficiary a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_ContingentBeneficiaryRole ;
    rdfs:label "has Contingent Beneficiary" ;
    rdfs:comment "Links a policy to the contingent beneficiary who may receive proceeds if the primary beneficiary predeceases the insured." .

:hasInterestRateReification a owl:ObjectProperty ;
    rdfs:domain :Cl_InterestOnDeathBenefitEvent ;
    rdfs:range :Cl_InterestRate ;
    rdfs:label "has Interest Rate Reification" ;
    rdfs:comment "Links the interest accrual event to the reified interest rate applied." .

:hasDeduction a owl:ObjectProperty ;
    rdfs:domain :Cl_DeathBenefitEvent ;
    rdfs:range :Cl_MonetaryAmount ;
    rdfs:label "has Deduction" ;
    rdfs:comment "Links the death benefit event to the amount deducted, such as unpaid premiums or indebtedness." .

:hasNetPayout a owl:ObjectProperty ;
    rdfs:domain :Cl_DeathBenefitEvent ;
    rdfs:range :Cl_MonetaryAmount ;
    rdfs:label "has Net Payout" ;
    rdfs:comment "Links the death benefit event to the final amount paid after deductions." .


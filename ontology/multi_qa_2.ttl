:ReinstatementPeriod_5Years a :Cl_ReinstatementPeriod ;
    :hasDuration "P5Y"^^xsd:duration .

:ReinstatementPeriod_StartEvent a :Cl_Lapse ;
    rdfs:label "Lapse Event" .

:ReinstatementPeriod_5Years :hasStartEvent :ReinstatementPeriod_StartEvent .
### New Classes and Properties from Managers Plan ###
:Cl_Lapse a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Lapse" ;
    rdfs:comment "An event marking the termination of policy coverage due to non-payment of premium after the grace period." .

:Cl_MissedPremium a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Missed Premium" ;
    rdfs:comment "An event indicating that a premium payment was not made by the due date." .

:Cl_Reinstatement a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Reinstatement" ;
    rdfs:comment "An event representing the restoration of a lapsed policy." .

:Cl_CoverageTerm a owl:Class ;
    rdfs:subClassOf :Cl_TimeInterval ;
    rdfs:label "Coverage Term" ;
    rdfs:comment "The period during which the policy provides coverage, from issue date to end date." .

### New Object Properties for Reification ###
:hasCoverageTerm a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_CoverageTerm ;
    rdfs:label "has Coverage Term" ;
    rdfs:comment "Links a policy to its coverage term interval." .

:hasLapseEvent a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Lapse ;
    rdfs:label "has Lapse Event" ;
    rdfs:comment "Indicates the event that caused the policy to lapse." .

:hasMissedPremiumEvent a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_MissedPremium ;
    rdfs:label "has Missed Premium Event" ;
    rdfs:comment "Indicates the event of a missed premium payment." .

:hasReinstatementEvent a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Reinstatement ;
    rdfs:label "has Reinstatement Event" ;
    rdfs:comment "Indicates the event of policy reinstatement." .

### Instantiating New Individuals from Contract ###
:Policy_EML202500028391 :hasCoverageTerm :CoverageTerm_2025to2045 .

:CoverageTerm_2025to2045 a :Cl_CoverageTerm ;
    :hasDuration "P20Y"^^xsd:duration ;
    :hasStartEvent :Event_IssueDate .

:Event_IssueDate a :Cl_Event ;
    rdfs:label "Issue Date Event" ;
    :hasManner "automatic" .

:MissedPremium_2025 a :Cl_MissedPremium ;
    rdfs:label "Missed Premium Payment in 2025" ;
    :hasAgentRole :PolicyOwner_JordanEllis ;
    :hasObjectRole :Policy_EML202500028391 ;
    :hasManner "late payment" .

:GracePeriod_31Days :hasStartEvent :MissedPremium_2025 .

:Lapse_2025 a :Cl_Lapse ;
    rdfs:label "Lapse Event in 2025" ;
    :hasAgentRole :PolicyOwner_JordanEllis ;
    :hasObjectRole :Policy_EML202500028391 ;
    :hasManner "non-payment" .

:Policy_EML202500028391 :hasLapseEvent :Lapse_2025 .

:Reinstatement_2026 a :Cl_Reinstatement ;
    rdfs:label "Reinstatement in 2026" ;
    :hasAgentRole :PolicyOwner_JordanEllis ;
    :hasObjectRole :Policy_EML202500028391 ;
    :hasManner "reinstatement application" .

:Policy_EML202500028391 :hasReinstatementEvent :Reinstatement_2026 .

:ReinstatementPeriod_5Years :hasStartEvent :Lapse_2025 .


@prefix : <http://www.example.org/test#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# Pivot Classes for Reification
:Cl_Event a owl:Class ;
    rdfs:label "Event" ;
    rdfs:comment "A discrete occurrence that alters the state or status of a policy." .

:Cl_State a owl:Class ;
    rdfs:label "State" ;
    rdfs:comment "A condition or status of a policy at a point in time." .

:Cl_MonetaryAmount a owl:Class ;
    rdfs:label "Monetary Amount" ;
    rdfs:comment "A quantified financial value associated with a policy." .

:Cl_TimeInterval a owl:Class ;
    rdfs:label "Time Interval" ;
    rdfs:comment "A duration of time with a start and end point." .

:Cl_AgentRole a owl:Class ;
    rdfs:label "Agent Role" ;
    rdfs:comment "A role played by an agent in a policy event." .

# Classes from Managers Plan
:Cl_Policy a owl:Class ;
    rdfs:label "Policy" ;
    rdfs:comment "A life insurance contract issued by Equivita Mutual Life Insurance Company to the Policy Owner." .

:Cl_Cancellation a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Cancellation" ;
    rdfs:comment "A policy termination event initiated by the Policy Owner." .

:Cl_PolicyOwnerRole a owl:Class ;
    rdfs:subClassOf :Cl_AgentRole ;
    rdfs:label "Policy Owner Role" ;
    rdfs:comment "The role of the Policy Owner in a policy event." .

:Cl_InsuredPersonRole a owl:Class ;
    rdfs:subClassOf :Cl_AgentRole ;
    rdfs:label "Insured Person Role" ;
    rdfs:comment "The role of the Insured Person in a policy event." .

:Cl_BeneficiaryRole a owl:Class ;
    rdfs:subClassOf :Cl_AgentRole ;
    rdfs:label "Beneficiary Role" ;
    rdfs:comment "The role of the Beneficiary in a policy event." .

:Cl_ReinstatementPeriod a owl:Class ;
    rdfs:subClassOf :Cl_TimeInterval ;
    rdfs:label "Reinstatement Period" ;
    rdfs:comment "A 5-year window during which a lapsed policy can be reinstated." .

:Cl_GracePeriod a owl:Class ;
    rdfs:subClassOf :Cl_TimeInterval ;
    rdfs:label "Grace Period" ;
    rdfs:comment "A 31-day period after a missed premium payment during which the policy remains active." .

# Object Properties
:hasEvent a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Event ;
    rdfs:label "has Event" ;
    rdfs:comment "Links a policy to the event that affects it." .

:hasState a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_State ;
    rdfs:label "is in State" ;
    rdfs:comment "Indicates the current state of a policy." .

:hasAgentRole a owl:ObjectProperty ;
    rdfs:domain :Cl_Event ;
    rdfs:range :Cl_AgentRole ;
    rdfs:label "has Agent Role" ;
    rdfs:comment "Links an event to the agent role involved." .

:hasObjectRole a owl:ObjectProperty ;
    rdfs:domain :Cl_Event ;
    rdfs:range :Cl_Policy ;
    rdfs:label "has Object Role" ;
    rdfs:comment "Links an event to the object (e.g., policy) it affects." .

:hasDeathBenefit a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_MonetaryAmount ;
    rdfs:label "has Death Benefit" ;
    rdfs:comment "The financial amount paid upon the death of the insured." .

:hasPremium a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_MonetaryAmount ;
    rdfs:label "has Premium" ;
    rdfs:comment "The periodic payment required to maintain coverage." .

:hasIssueDate a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:date ;
    rdfs:label "has Issue Date" ;
    rdfs:comment "The date the policy was issued." .

:hasPolicyOwner a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyOwnerRole ;
    rdfs:label "has Policy Owner" ;
    rdfs:comment "The role of the individual who owns the policy." .

:hasInsuredPerson a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_InsuredPersonRole ;
    rdfs:label "has Insured Person" ;
    rdfs:comment "The role of the individual whose life is insured." .

:hasBeneficiary a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_BeneficiaryRole ;
    rdfs:label "has Beneficiary" ;
    rdfs:comment "The role of the individual who receives the death benefit." .

:hasManner a owl:ObjectProperty ;
    rdfs:domain :Cl_Event ;
    rdfs:range xsd:string ;
    rdfs:label "has Manner" ;
    rdfs:comment "The required method or form for initiating an event." .

:hasDuration a owl:ObjectProperty ;
    rdfs:domain :Cl_TimeInterval ;
    rdfs:range xsd:duration ;
    rdfs:label "has Duration" ;
    rdfs:comment "The length of time for a temporal interval." .

:hasStartEvent a owl:ObjectProperty ;
    rdfs:domain :Cl_TimeInterval ;
    rdfs:range :Cl_Event ;
    rdfs:label "has Start Event" ;
    rdfs:comment "The event that triggers the start of a time interval." .

# Data Properties
:hasAmount a owl:DatatypeProperty ;
    rdfs:domain :Cl_MonetaryAmount ;
    rdfs:range xsd:decimal ;
    rdfs:label "has Amount" ;
    rdfs:comment "The numeric value of a monetary amount." .

:hasCurrency a owl:DatatypeProperty ;
    rdfs:domain :Cl_MonetaryAmount ;
    rdfs:range xsd:string ;
    rdfs:label "has Currency" ;
    rdfs:comment "The currency unit of a monetary amount." .

# Instantiating the Policy and Related Entities
:Policy_EML202500028391 a :Cl_Policy ;
    :hasIssueDate "2025-08-01"^^xsd:date ;
    :hasPolicyOwner :PolicyOwner_JordanEllis ;

    :hasBeneficiary :Beneficiary_TaylorEllis ;
    :hasDeathBenefit :DeathBenefit_500000 ;
    :hasPremium :Premium_100 ;
    :hasState :State_Active ;
    :hasEvent :Event_Cancellation .

:PolicyOwner_JordanEllis a :Cl_PolicyOwnerRole ;
    rdfs:label "Jordan Ellis" .

:InsuredPerson_JordanEllis a :Cl_InsuredPersonRole ;
    rdfs:label "Jordan Ellis" .

:Beneficiary_TaylorEllis a :Cl_BeneficiaryRole ;
    rdfs:label "Taylor Ellis" .

:DeathBenefit_500000 a :Cl_MonetaryAmount ;
    :hasAmount 500000.0 ;
    :hasCurrency "USD" .

:Premium_100 a :Cl_MonetaryAmount ;
    :hasAmount 100.0 ;
    :hasCurrency "USD" .

:State_Active a :Cl_State ;
    rdfs:label "Active" .

:State_InGracePeriod a :Cl_State ;
    rdfs:label "In Grace Period" .

:State_Lapsed a :Cl_State ;
    rdfs:label "Lapsed" .

:Event_Cancellation a :Cl_Cancellation ;
    :hasAgentRole :PolicyOwner_JordanEllis ;
    :hasObjectRole :Policy_EML202500028391 ;
    :hasManner "written notice" .


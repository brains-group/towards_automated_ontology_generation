### Adding New Classes: IncontestabilityPeriod and SuicideExclusionPeriod ###
:Cl_IncontestabilityPeriod a owl:Class ;
    rdfs:subClassOf :Cl_TimeInterval ;
    rdfs:label "Incontestability Period" ;
    rdfs:comment "A two-year period during which the Company may contest the validity of the Policy." .

:Cl_SuicideExclusionPeriod a owl:Class ;
    rdfs:subClassOf :Cl_TimeInterval ;
    rdfs:label "Suicide Exclusion Period" ;
    rdfs:comment "A two-year period during which the death benefit is limited if the Insured dies by suicide." .

### Adding New Object Properties: hasIncontestabilityPeriod and hasSuicideExclusionPeriod ###
:hasIncontestabilityPeriod a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_IncontestabilityPeriod ;
    rdfs:label "has Incontestability Period" ;
    rdfs:comment "Links a policy to its incontestability period." .

:hasSuicideExclusionPeriod a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_SuicideExclusionPeriod ;
    rdfs:label "has Suicide Exclusion Period" ;
    rdfs:comment "Links a policy to its suicide exclusion period." .

### Adding New Class: PolicyAnniversary ###
:Cl_PolicyAnniversary a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Policy Anniversary" ;
    rdfs:comment "An annual event marking the anniversary of the policy's Issue Date." .

### Adding New Object Property: hasPolicyAnniversary ###
:hasPolicyAnniversary a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyAnniversary ;
    rdfs:label "has Policy Anniversary" ;
    rdfs:comment "Links a policy to its policy anniversary event." .

### Adding New Data Property: hasAnniversaryFrequency ###
:hasAnniversaryFrequency a owl:DatatypeProperty ;
    rdfs:domain :Cl_PolicyAnniversary ;
    rdfs:range xsd:duration ;
    rdfs:label "has Anniversary Frequency" ;
    rdfs:comment "The frequency of the policy anniversary event, e.g., yearly." .

### Instantiating IncontestabilityPeriod and SuicideExclusionPeriod for the Policy ###
:Policy_EML202500028391 :hasIncontestabilityPeriod :IncontestabilityPeriod_2Years .
:Policy_EML202500028391 :hasSuicideExclusionPeriod :SuicideExclusionPeriod_2Years .

:IncontestabilityPeriod_2Years a :Cl_IncontestabilityPeriod ;
    :hasDuration "P2Y"^^xsd:duration ;
    :hasStartEvent :Event_IssueDate .

:SuicideExclusionPeriod_2Years a :Cl_SuicideExclusionPeriod ;
    :hasDuration "P2Y"^^xsd:duration ;
    :hasStartEvent :Event_IssueDate .

### Instantiating PolicyAnniversary Event and Linking to Policy ###
:PolicyAnniversary_2026 a :Cl_PolicyAnniversary ;
    rdfs:label "Policy Anniversary in 2026" ;
    :hasObjectRole :Policy_EML202500028391 ;
    :hasAgentRole :PolicyOwner_JordanEllis ;
    :hasManner "automatic" ;
    :hasAnniversaryFrequency "P1Y"^^xsd:duration .

:Policy_EML202500028391 :hasPolicyAnniversary :PolicyAnniversary_2026 .

### Finalizing Coverage Term with Correct Duration and Start Event ###
:CoverageTerm_2025to2045 :hasStartEvent :Event_IssueDate ;
    :hasDuration "P20Y"^^xsd:duration .

### Adding Missing Grace Period Duration and Start Event Link ###

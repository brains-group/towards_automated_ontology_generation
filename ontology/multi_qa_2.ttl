    :hasStartEvent :MissedPremium_2025 .
### Adding New Classes: Cl_Assignment, Cl_Modifications, Cl_MisstatementOfAgeOrSex, Cl_PolicyOwnerRights, Cl_VoidAbInitio ###
:Cl_Assignment a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Assignment" ;
    rdfs:comment "An event in which the Policy Owner assigns the Policy or any rights under it to another party." .

:Cl_Modifications a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Modifications" ;
    rdfs:comment "An event representing a formal change or update to the Policy by the Company." .

:Cl_MisstatementOfAgeOrSex a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Misstatement of Age or Sex" ;
    rdfs:comment "An event indicating that the age or sex of the Insured was incorrectly stated at issue." .

:Cl_PolicyOwnerRights a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Policy Owner Rights" ;
    rdfs:comment "An event in which the Policy Owner exercises any contractual right under the Policy." .

:Cl_VoidAbInitio a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Void Ab Initio" ;
    rdfs:comment "An event marking the Policy as void from inception due to the Insured being outside the insurable age range." .

### Adding New Object Properties: hasAssignment, hasModifications, hasMisstatementOfAgeOrSex, hasPolicyOwnerRights, hasVoidAbInitio ###
:hasAssignment a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Assignment ;
    rdfs:label "has Assignment" ;
    rdfs:comment "Links a policy to the assignment event initiated by the Policy Owner." .

:hasModifications a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Modifications ;
    rdfs:label "has Modifications" ;
    rdfs:comment "Links a policy to the modifications event initiated by the Company." .

:hasMisstatementOfAgeOrSex a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_MisstatementOfAgeOrSex ;
    rdfs:label "has Misstatement of Age or Sex" ;
    rdfs:comment "Links a policy to the misstatement event related to age or sex." .

:hasPolicyOwnerRights a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyOwnerRights ;
    rdfs:label "has Policy Owner Rights" ;
    rdfs:comment "Links a policy to the event in which the Policy Owner exercises rights." .

:hasVoidAbInitio a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_VoidAbInitio ;
    rdfs:label "has Void Ab Initio" ;
    rdfs:comment "Links a policy to the event in which the Policy is voided ab initio due to age range." .


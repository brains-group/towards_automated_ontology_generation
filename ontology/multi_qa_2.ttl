### Adding New Classes: Cl_IncontestabilityPeriod, Cl_SuicideExclusionPeriod, Cl_Incontestability, Cl_SuicideExclusion ###
:Cl_IncontestabilityPeriod a owl:Class ;
    rdfs:subClassOf :Cl_TimeInterval ;
    rdfs:label "Incontestability Period" ;
    rdfs:comment "A two-year period during which the Company may contest the validity of the Policy due to misrepresentation, starting from the Issue Date." .

:Cl_SuicideExclusionPeriod a owl:Class ;
    rdfs:subClassOf :Cl_TimeInterval ;
    rdfs:label "Suicide Exclusion Period" ;
    rdfs:comment "A two-year period during which the death benefit is limited to total premiums paid if the Insured dies by suicide, starting from the Issue Date or Reinstatement Date." .

:Cl_Incontestability a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Incontestability" ;
    rdfs:comment "The event marking the end of the contestability period, after which the policy becomes incontestable unless fraud is involved." .

:Cl_SuicideExclusion a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Suicide Exclusion" ;
    rdfs:comment "The event marking the occurrence of suicide within the exclusion period, triggering limited liability." .

### Adding New Object Properties: hasIncontestabilityPeriod, hasSuicideExclusionPeriod, hasIncontestability, hasSuicideExclusion ###
:hasIncontestabilityPeriod a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_IncontestabilityPeriod ;
    rdfs:label "has Incontestability Period" ;
    rdfs:comment "Links a policy to its incontestability period." .

:hasSuicideExclusionPeriod a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_SuicideExclusionPeriod ;
    rdfs:label "has Suicide Exclusion Period" ;
    rdfs:comment "Links a policy to its suicide exclusion period." .

:hasIncontestability a owl:ObjectProperty ;
    rdfs:domain :Cl_IncontestabilityPeriod ;
    rdfs:range :Cl_Incontestability ;
    rdfs:label "has Incontestability" ;
    rdfs:comment "Links the incontestability period to the event marking its end." .

:hasSuicideExclusion a owl:ObjectProperty ;
    rdfs:domain :Cl_SuicideExclusionPeriod ;
    rdfs:range :Cl_SuicideExclusion ;
    rdfs:label "has Suicide Exclusion" ;
    rdfs:comment "Links the suicide exclusion period to the event of suicide within the period." .


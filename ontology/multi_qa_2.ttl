### Adding New Classes: Cl_DesignationOfBeneficiary, Cl_ChangeOfBeneficiary, Cl_SimultaneousDeathAndDisclaimer, Cl_FacilityOfPayment, Cl_EstateRole, Cl_EquitableRecipientRole ###
:Cl_DesignationOfBeneficiary a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Designation of Beneficiary" ;
    rdfs:comment "A discrete event in which the Policy Owner formally names a Beneficiary in writing and files it with the Company." .

:Cl_ChangeOfBeneficiary a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Change of Beneficiary" ;
    rdfs:comment "A discrete event in which the Policy Owner updates the Beneficiary designation, subject to policy terms and consent requirements." .

:Cl_SimultaneousDeathAndDisclaimer a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Simultaneous Death and Disclaimer" ;
    rdfs:comment "An event triggered when the Insured and Beneficiary die under circumstances making the order of death uncertain, or when a Beneficiary disclaims proceeds." .

:Cl_FacilityOfPayment a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Facility of Payment" ;
    rdfs:comment "The event in which the Company pays proceeds to the Insured's estate or an equitable recipient due to the absence or unlocatability of a surviving Beneficiary." .

:Cl_EstateRole a owl:Class ;
    rdfs:subClassOf :Cl_AgentRole ;
    rdfs:label "Estate Role" ;
    rdfs:comment "A role played by the Insured's estate in a policy event." .

:Cl_EquitableRecipientRole a owl:Class ;
    rdfs:subClassOf :Cl_AgentRole ;
    rdfs:label "Equitable Recipient Role" ;
    rdfs:comment "A role played by a person deemed by the Company to be equitably entitled to proceeds." .

### Adding New Object Properties: hasEstateRecipient, hasEquitableRecipient ###
:hasEstateRecipient a owl:ObjectProperty ;
    rdfs:domain :Cl_FacilityOfPayment ;
    rdfs:range :Cl_EstateRole ;
    rdfs:label "has Estate Recipient" ;
    rdfs:comment "Links a Facility of Payment event to the Insured's estate as recipient." .

:hasEquitableRecipient a owl:ObjectProperty ;
    rdfs:domain :Cl_FacilityOfPayment ;
    rdfs:range :Cl_EquitableRecipientRole ;
    rdfs:label "has Equitable Recipient" ;
    rdfs:comment "Links a Facility of Payment event to a person deemed equitably entitled." .


    :objProp_hasGracePeriod :ind_GracePeriod ;
    :objProp_hasReinstatementPeriod :ind_ReinstatementPeriod ;
    :objProp_hasLapsedState :ind_LapsedPolicy ;
    :dataProp_faceAmount "500000"^^xsd:decimal ;
    :dataProp_currencyUnit "USD" ;
    :dataProp_issueDate "2025-08-01T00:00:00"^^xsd:dateTime .

:ind_PolicyOwner_JordanEllis a :Cl_PolicyOwner ;
    rdfs:label "Jordan Ellis" .

:ind_InsuredPerson_JordanEllis a :Cl_InsuredPerson ;
    rdfs:label "Jordan Ellis" .

:ind_Beneficiary_TaylorEllis a :Cl_Beneficiary ;
    rdfs:label "Taylor Ellis" .

:ind_PolicyType_Term20Year a :Cl_PolicyType ;
    rdfs:label "20-Year Level Term" .

:ind_PolicyState_Active a :Cl_PolicyState ;
    rdfs:label "Active" .

:ind_PolicyState_GracePeriod a :Cl_PolicyState ;
    rdfs:label "In Grace Period" .

:ind_PolicyState_Lapsed a :Cl_PolicyState ;
    rdfs:label "Lapsed" .

:ind_Cancellation a :Cl_Cancellation ;
    rdfs:label "Cancellation" ;
    :objProp_isInitiatedBy :ind_PolicyOwner_JordanEllis ;

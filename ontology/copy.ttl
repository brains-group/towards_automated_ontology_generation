    rdfs:label "Contingent Beneficiary Consideration" ;
    :objProp_hasContingentBeneficiaryConsiderationEvent :ind_Policy_EML202500028391 ;
    :objProp_participatesInContingentBeneficiaryConsideration :ind_Company_Equivita ;
    :objProp_hasContingentBeneficiaryForDeathBenefit :ind_Beneficiary_TaylorEllis ;
    :objProp_hasEstateForDeathBenefit :ind_PolicyOwner_JordanEllis .


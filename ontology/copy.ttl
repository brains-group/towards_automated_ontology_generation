# --- New Restrictions for Page 8 ---
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom :Cl_Reinstatement ;
            owl:onProperty :objProp_hasReinstatementEvent
        ]
        [
            owl:allValuesFrom :Cl_ReinstatementPeriodInterval ;
            owl:onProperty :objProp_hasReinstatementPeriodInterval
        ]
        [
            owl:allValuesFrom :Cl_Conversion ;
            owl:onProperty :objProp_hasConversionEvent
        ]
        [
            owl:allValuesFrom :Cl_ConversionPeriod ;
            owl:onProperty :objProp_hasConversionPeriod
        ]
        [
            owl:allValuesFrom :Cl_PolicyLapse ;
            owl:onProperty :objProp_hasPolicyLapseEvent
        ]
        [
            owl:allValuesFrom :Cl_PolicyRestoration ;
            owl:onProperty :objProp_hasPolicyRestorationEvent
        ]
    )
] .

:Cl_Reinstatement owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Reinstatement
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredMannerReinstatement
        ]
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredEvidenceOfInsurability
        ]
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredPaymentForReinstatement
        ]
        [
            owl:allValuesFrom xsd:integer ;
            owl:onProperty :dataProp_newContestabilityPeriodDuration
        ]
        [
            owl:allValuesFrom xsd:integer ;
            owl:onProperty :dataProp_newSuicideExclusionPeriodDuration
        ]
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_participatesInReinstatement
        ]
    )
] .

:Cl_ReinstatementPeriodInterval owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_ReinstatementPeriodInterval
        [
            owl:allValuesFrom xsd:integer ;
            owl:onProperty :dataProp_durationInDaysReinstatementPeriod
        ]
    )
] .

:Cl_Conversion owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Conversion
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredMannerConversion
        ]
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredAgeLimit
        ]
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredPaymentForConversion
        ]
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_participatesInConversion
        ]
    )
] .

:Cl_PolicyLapse owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_PolicyLapse
        [
            owl:allValuesFrom xsd:integer ;
            owl:onProperty :dataProp_maxDurationLapsedState
        ]
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_participatesInPolicyLapse
        ]
    )
] .

:Cl_PolicyRestoration owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_PolicyRestoration
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_participatesInPolicyRestoration
        ]
    )
] .


    rdfs:label "Incontestability Period" ;
    :objProp_hasIncontestabilityPeriod :ind_Policy_EML202500028391 ;
    :objProp_participatesInIncontestabilityPeriod :ind_Policy_EML202500028391 ;
    :dataProp_eventStart "2025-08-01T00:00:00"^^xsd:dateTime ;
    :dataProp_durationInDaysIncontestabilityPeriod "730"^^xsd:integer .

:ind_SuicideExclusionPeriodEvent a :Cl_SuicideExclusionPeriod ;
    rdfs:label "Suicide Exclusion Period" ;
    :objProp_hasSuicideExclusionPeriod :ind_Policy_EML202500028391 ;
    :objProp_participatesInSuicideExclusionPeriod :ind_Policy_EML202500028391 ;

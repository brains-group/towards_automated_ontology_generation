# --- New Classes for Page 7: Contestability and Suicide Clause ---
:Cl_IncontestabilityPeriodEvent a owl:Class ;
    rdfs:label "Incontestability Period Event" ;
    rdfs:comment "The event when a policy becomes incontestable after the initial two-year period." ;
    rdfs:subClassOf :Cl_Event .

:Cl_ContestabilityPeriodAfterReinstatement a owl:Class ;
    rdfs:label "Contestability Period After Reinstatement" ;
    rdfs:comment "The event when a new two-year contestability period begins after a policy is reinstated." ;
    rdfs:subClassOf :Cl_Event .

:Cl_SuicideExclusionEvent a owl:Class ;
    rdfs:label "Suicide Exclusion Event" ;
    rdfs:comment "The event when the insured dies by suicide within two years of the issue date or reinstatement date." ;
    rdfs:subClassOf :Cl_Event .

:Cl_SuicideExclusionPeriodEvent a owl:Class ;
    rdfs:label "Suicide Exclusion Period Event" ;
    rdfs:comment "The event when the suicide exclusion period begins from the issue date or reinstatement date." ;
    rdfs:subClassOf :Cl_Event .


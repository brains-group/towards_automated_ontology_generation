# --- New Restrictions for Page 4 ---
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom :Cl_PremiumPayment ;
            owl:onProperty :objProp_hasPremiumPayment
        ]
        [
            owl:allValuesFrom :Cl_PremiumNotPaid ;
            owl:onProperty :objProp_hasPremiumNotPaidEvent
        ]
        [
            owl:allValuesFrom :Cl_GracePeriodEvent ;
            owl:onProperty :objProp_hasGracePeriodEvent
        ]
        [
            owl:allValuesFrom :Cl_LapseForNonpayment ;
            owl:onProperty :objProp_hasLapseForNonpaymentEvent
        ]
        [
            owl:allValuesFrom :Cl_ReinstatementEvent ;
            owl:onProperty :objProp_hasReinstatementEvent
        ]
        [
            owl:allValuesFrom :Cl_ReinstatementPeriodInterval ;
            owl:onProperty :objProp_hasReinstatementPeriodInterval
        ]
        [
            owl:allValuesFrom :Cl_PolicyTermination ;
            owl:onProperty :objProp_hasPolicyTerminationEvent
        ]
        [
            owl:allValuesFrom :Cl_PolicyRestoration ;
            owl:onProperty :objProp_hasPolicyRestorationEvent
        ]
    )
] .

:Cl_PremiumNotPaid owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_PremiumNotPaid
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_participatesInPremiumNotPaid
        ]
    )
] .

:Cl_LapseForNonpayment owl:equivalentClass [

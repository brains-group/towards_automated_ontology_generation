# --- New Classes for Page 8: Reinstatement and Conversion ---
:Cl_Reinstatement a owl:Class ;
    rdfs:label "Reinstatement" ;
    rdfs:comment "The event when a lapsed policy is restored to active status after meeting reinstatement conditions." ;
    rdfs:subClassOf :Cl_Event .

:Cl_ReinstatementPeriodInterval a owl:Class ;
    rdfs:label "Reinstatement Period Interval" ;
    rdfs:comment "The time interval during which a lapsed policy can be reinstated, up to five years from the date of lapse." ;
    rdfs:subClassOf :Cl_Event .

:Cl_Conversion a owl:Class ;
    rdfs:label "Conversion" ;
    rdfs:comment "The event when a term policy is converted to a permanent life insurance policy without evidence of insurability." ;
    rdfs:subClassOf :Cl_Event .

:Cl_ConversionPeriod a owl:Class ;
    rdfs:label "Conversion Period" ;
    rdfs:comment "The time interval during which a policy owner may convert a term policy to a permanent policy." ;
    rdfs:subClassOf :Cl_Event .

:Cl_PolicyLapse a owl:Class ;
    rdfs:label "Policy Lapse" ;
    rdfs:comment "The event when a policy's coverage is terminated due to nonpayment of premiums after the grace period." ;
    rdfs:subClassOf :Cl_Event .

:Cl_PolicyRestoration a owl:Class ;
    rdfs:label "Policy Restoration" ;
    rdfs:comment "The event when a lapsed policy is restored to active status through reinstatement." ;
    rdfs:subClassOf :Cl_Event .

# --- New Object Properties for Page 8 ---
:objProp_hasReinstatementEvent a owl:ObjectProperty ;
    rdfs:label "hasReinstatementEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Reinstatement .

:objProp_hasReinstatementPeriodInterval a owl:ObjectProperty ;
    rdfs:label "hasReinstatementPeriodInterval" ;
    rdfs:domain :Cl_Policy ;

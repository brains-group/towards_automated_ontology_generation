    :dataProp_durationInDaysSuicideExclusionPeriod "730"^^xsd:integer .

:ind_GracePeriodEvent a :Cl_GracePeriodEvent ;
    rdfs:label "Grace Period Event" ;
    :objProp_hasGracePeriodEvent :ind_Policy_EML202500028391 ;
    :objProp_participatesInGracePeriodEvent :ind_Policy_EML202500028391 ;

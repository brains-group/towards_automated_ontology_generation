    :objProp_hasSimultaneousDeathAssumptionEvent :ind_Policy_EML202500028391 ;
    :objProp_participatesInSimultaneousDeathAssumption :ind_Company_Equivita ;
    :dataProp_assumptionInSimultaneousDeath "The Beneficiary predeceased the Insured unless otherwise governed by state law" .

# --- New Restrictions for Page 5 ---
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom :Cl_DeathBenefit ;
            owl:onProperty :objProp_hasDeathBenefitEvent
        ]
        [
            owl:allValuesFrom :Cl_ProofOfDeath ;
            owl:onProperty :objProp_hasProofOfDeathEvent
        ]
        [
            owl:allValuesFrom :Cl_PaymentOfProceeds ;
            owl:onProperty :objProp_hasPaymentOfProceedsEvent
        ]
        [
            owl:allValuesFrom :Cl_InterestOnDeathBenefit ;
            owl:onProperty :objProp_hasInterestOnDeathBenefitEvent
        ]
        [
            owl:allValuesFrom :Cl_ContingentBeneficiaryConsideration ;
            owl:onProperty :objProp_hasContingentBeneficiaryConsiderationEvent
        ]
        [
            owl:allValuesFrom :Cl_SimultaneousDeathAssumption ;
            owl:onProperty :objProp_hasSimultaneousDeathAssumptionEvent
        ]
    )
] .

:Cl_DeathBenefit owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_DeathBenefit
        [
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty :dataProp_deathBenefitAmount
        ]
        [
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty :dataProp_deductionApplied
        ]
        [
            owl:allValuesFrom :Cl_Beneficiary ;
            owl:onProperty :objProp_hasBeneficiaryForDeathBenefit
        ]
    )
] .

:Cl_ProofOfDeath owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_ProofOfDeath
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredDocumentation
        ]
    )
] .

:Cl_PaymentOfProceeds owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_PaymentOfProceeds
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_defaultPaymentMethod
        ]
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_alternativePaymentOptionCondition
        ]
    )
] .

:Cl_InterestOnDeathBenefit owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_InterestOnDeathBenefit
        [
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty :dataProp_interestRate
        ]
        [
            owl:allValuesFrom xsd:duration ;
            owl:onProperty :dataProp_timeIntervalForInterestAccrual
        ]
    )
] .

:Cl_ContingentBeneficiaryConsideration owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_ContingentBeneficiaryConsideration
        [
            owl:allValuesFrom :Cl_Beneficiary ;
            owl:onProperty :objProp_hasContingentBeneficiaryForDeathBenefit
        ]
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_hasEstateForDeathBenefit
        ]
    )
] .

:Cl_SimultaneousDeathAssumption owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_SimultaneousDeathAssumption
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_assumptionInSimultaneousDeath
        ]
    )
] .



# --- New Classes for Page 6: Beneficiary Provisions ---
:Cl_DesignationOfBeneficiary a owl:Class ;
    rdfs:label "Designation of Beneficiary" ;
    rdfs:comment "The event when the Policy Owner formally designates a Beneficiary to receive the death benefit upon the Insured's death." ;
    rdfs:subClassOf :Cl_Event .

:Cl_ChangeOfBeneficiary a owl:Class ;
    rdfs:label "Change of Beneficiary" ;
    rdfs:comment "The event when the Policy Owner changes the designated Beneficiary during the lifetime of the Insured." ;
    rdfs:subClassOf :Cl_Event .

:Cl_IrrevocableBeneficiaryDesignation a owl:Class ;
    rdfs:label "Irrevocable Beneficiary Designation" ;
    rdfs:comment "The event when the Policy Owner designates a Beneficiary as irrevocable, restricting the owner's rights to change or assign the policy without consent." ;
    rdfs:subClassOf :Cl_Event .

:Cl_SimultaneousDeathAndDisclaimer a owl:Class ;
    rdfs:label "Simultaneous Death and Disclaimer" ;
    rdfs:comment "The event when the Insured and the Beneficiary die under circumstances that make the order of death uncertain, or when the Beneficiary disclaims the proceeds." ;
    rdfs:subClassOf :Cl_Event .

:Cl_FacilityOfPayment a owl:Class ;
    rdfs:label "Facility of Payment" ;
    rdfs:comment "The event when no Beneficiary survives the Insured or cannot be located within 90 days, and the Company pays the proceeds to the Insured's estate or another equitably entitled person." ;
    rdfs:subClassOf :Cl_Event .


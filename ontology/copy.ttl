    rdfs:label "Reinstatement Period" ;
    :dataProp_durationInDays "60"^^xsd:integer ;
    :dataProp_eventStart "2025-08-01T00:00:00"^^xsd:dateTime .

:ind_LapsedPolicy a :Cl_LapsedPolicy ;
    rdfs:label "Lapsed Policy" ;
    :dataProp_eventStart "2025-08-01T00:00:00"^^xsd:dateTime .


# --- Additional Axioms and Restrictions ---

# Restriction: A policy must have a face amount
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty :dataProp_faceAmount
        ]
    )
] .

# Restriction: A policy must have a currency unit
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_currencyUnit
        ]
    )
] .

# Restriction: A policy must have a policy type
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom :Cl_PolicyType ;
            owl:onProperty :objProp_hasPolicyType
        ]
    )
] .

# Restriction: A policy must have a policy owner
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_hasOwner
        ]
    )
] .

# Restriction: A policy must have an insured person
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom :Cl_InsuredPerson ;
            owl:onProperty :objProp_hasInsured
        ]
    )
] .

# Restriction: A policy must have a beneficiary
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom :Cl_Beneficiary ;
            owl:onProperty :objProp_hasBeneficiary
        ]
    )
] .

# Restriction: A policy must have a state
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom :Cl_PolicyState ;
            owl:onProperty :objProp_hasState
        ]
    )
] .

# Restriction: A cancellation must be initiated by a policy owner
:Cl_Cancellation owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Cancellation
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_isInitiatedBy
        ]
    )
] .

# Restriction: A grace period must have a duration
:Cl_GracePeriod owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_GracePeriod
        [
            owl:allValuesFrom xsd:integer ;
            owl:onProperty :dataProp_durationInDaysGracePeriod
        ]
    )
] .

# Restriction: A reinstatement period must have a duration
:Cl_ReinstatementPeriod owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_ReinstatementPeriod
        [
            owl:allValuesFrom xsd:integer ;
            owl:onProperty :dataProp_durationInDays
        ]
    )
] .

# --- Event Reification and State Transitions ---

# A policy transitions from 'Active' to 'In Grace Period' when a premium is not paid
:ind_PremiumNotPaidEvent a :Cl_Event ;
    rdfs:label "Premium Not Paid" ;
    :objProp_hasEvent :ind_Policy_EML202500028391 ;
    :objProp_participatesIn :ind_PolicyOwner_JordanEllis ;
    :dataProp_eventStart "2025-08-01T00:00:00"^^xsd:dateTime .

# The grace period begins when a premium is not paid
:ind_GracePeriodStartEvent a :Cl_GracePeriod ;
    rdfs:label "Grace Period Start" ;
    :objProp_hasEvent :ind_Policy_EML202500028391 ;
    :dataProp_eventStart "2025-08-01T00:00:00"^^xsd:dateTime .

# The policy enters 'Lapsed' state if premium is not paid by end of grace period
:ind_PolicyLapsedEvent a :Cl_LapsedPolicy ;
    rdfs:label "Policy Lapsed" ;
    :objProp_hasEvent :ind_Policy_EML202500028391 ;
    :dataProp_eventStart "2025-08-01T00:00:00"^^xsd:dateTime .

# The cancellation event is initiated by the policy owner
:ind_CancellationInitiated a :Cl_Cancellation ;
    rdfs:label "Cancellation Initiated" ;
    :objProp_isInitiatedBy :ind_PolicyOwner_JordanEllis ;
    :objProp_hasInitiationMethod "Written Request" ;
    :dataProp_eventStart "2025-08-01T00:00:00"^^xsd:dateTime .


# --- New Classes for Events ---
:Cl_Lapse a owl:Class ;
    rdfs:label "Lapse" ;
    rdfs:comment "The event when a policy's coverage is terminated due to nonpayment of premiums after the grace period." ;
    rdfs:subClassOf :Cl_Event .

:Cl_Reinstatement a owl:Class ;
    rdfs:label "Reinstatement" ;
    rdfs:comment "The event when a lapsed policy is restored to active status." ;
    rdfs:subClassOf :Cl_Event .

:Cl_IncontestabilityPeriod a owl:Class ;
    rdfs:label "Incontestability Period" ;
    rdfs:comment "The two-year period during which the company may contest the validity of the policy." ;
    rdfs:subClassOf :Cl_Event .

:Cl_SuicideExclusionPeriod a owl:Class ;
    rdfs:label "Suicide Exclusion Period" ;
    rdfs:comment "The two-year period during which the death benefit is limited if the insured dies by suicide." ;
    rdfs:subClassOf :Cl_Event .

:Cl_GracePeriodEvent a owl:Class ;
    rdfs:label "Grace Period Event" ;
    rdfs:comment "The event when a policy remains in force after a premium due date during which the policy remains in force." ;
    rdfs:subClassOf :Cl_Event .

:Cl_PolicyAnniversary a owl:Class ;
    rdfs:label "Policy Anniversary" ;
    rdfs:comment "The event that occurs on each yearly anniversary of the policy's issue date." ;
    rdfs:subClassOf :Cl_Event .


# --- New Object Properties for Event Participants ---
:objProp_hasLapseEvent a owl:ObjectProperty ;
    rdfs:label "hasLapseEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Lapse .

:objProp_hasReinstatementEvent a owl:ObjectProperty ;
    rdfs:label "hasReinstatementEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Reinstatement .

:objProp_hasIncontestabilityPeriod a owl:ObjectProperty ;
    rdfs:label "hasIncontestabilityPeriod" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_IncontestabilityPeriod .

:objProp_hasSuicideExclusionPeriod a owl:ObjectProperty ;
    rdfs:label "hasSuicideExclusionPeriod" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_SuicideExclusionPeriod .

:objProp_hasGracePeriodEvent a owl:ObjectProperty ;
    rdfs:label "hasGracePeriodEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_GracePeriodEvent .

:objProp_hasPolicyAnniversary a owl:ObjectProperty ;
    rdfs:label "hasPolicyAnniversary" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyAnniversary .

:objProp_participatesInLapse a owl:ObjectProperty ;
    rdfs:label "participatesInLapse" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Lapse .

:objProp_participatesInReinstatement a owl:ObjectProperty ;
    rdfs:label "participatesInReinstatement" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Reinstatement .

:objProp_participatesInIncontestabilityPeriod a owl:ObjectProperty ;
    rdfs:label "participatesInIncontestabilityPeriod" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_IncontestabilityPeriod .

:objProp_participatesInSuicideExclusionPeriod a owl:ObjectProperty ;
    rdfs:label "participatesInSuicideExclusionPeriod" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_SuicideExclusionPeriod .

:objProp_participatesInGracePeriodEvent a owl:ObjectProperty ;
    rdfs:label "participatesInGracePeriodEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_GracePeriodEvent .

:objProp_participatesInPolicyAnniversary a owl:ObjectProperty ;
    rdfs:label "participatesInPolicyAnniversary" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyAnniversary .


# --- New Data Properties for Event Durations and Frequencies ---
:dataProp_durationInDaysIncontestabilityPeriod a owl:DatatypeProperty ;
    rdfs:label "durationInDaysIncontestabilityPeriod" ;
    rdfs:domain :Cl_IncontestabilityPeriod ;
    rdfs:range xsd:integer .

:dataProp_durationInDaysSuicideExclusionPeriod a owl:DatatypeProperty ;
    rdfs:label "durationInDaysSuicideExclusionPeriod" ;
    rdfs:domain :Cl_SuicideExclusionPeriod ;
    rdfs:range xsd:integer .

:dataProp_durationInDaysGracePeriodEvent a owl:DatatypeProperty ;
    rdfs:label "durationInDaysGracePeriodEvent" ;
    rdfs:domain :Cl_GracePeriodEvent ;
    rdfs:range xsd:integer .

:dataProp_frequencyPolicyAnniversary a owl:DatatypeProperty ;
    rdfs:label "frequencyPolicyAnniversary" ;
    rdfs:domain :Cl_PolicyAnniversary ;
    rdfs:range xsd:string .


# --- New Individuals for Events ---
:ind_LapseEvent a :Cl_Lapse ;
    rdfs:label "Policy Lapse" ;
    :objProp_hasLapseEvent :ind_Policy_EML202500028391 ;
    :objProp_participatesInLapse :ind_Policy_EML202500028391 ;

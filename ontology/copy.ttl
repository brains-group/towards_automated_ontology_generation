    :objProp_participatesInPolicyAnniversary :ind_Policy_EML202500028391 ;
    :dataProp_eventStart "2025-08-01T00:00:00"^^xsd:dateTime ;
    :dataProp_frequencyPolicyAnniversary "Yearly" .


# --- New Restrictions for Event Properties ---
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom :Cl_Lapse ;
            owl:onProperty :objProp_hasLapseEvent
        ]
        [
            owl:allValuesFrom :Cl_Reinstatement ;
            owl:onProperty :objProp_hasReinstatementEvent
        ]
        [
            owl:allValuesFrom :Cl_IncontestabilityPeriod ;
            owl:onProperty :objProp_hasIncontestabilityPeriod
        ]
        [
            owl:allValuesFrom :Cl_SuicideExclusionPeriod ;
            owl:onProperty :objProp_hasSuicideExclusionPeriod
        ]
        [
            owl:allValuesFrom :Cl_GracePeriodEvent ;
            owl:onProperty :objProp_hasGracePeriodEvent
        ]
        [
            owl:allValuesFrom :Cl_PolicyAnniversary ;
            owl:onProperty :objProp_hasPolicyAnniversary
        ]
    )
] .

:Cl_Lapse owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Lapse
        [
            owl:allValuesFrom :Cl_Policy ;
            owl:onProperty :objProp_hasLapseEvent
        ]
    )
] .

:Cl_Reinstatement owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Reinstatement
        [
            owl:allValuesFrom :Cl_Policy ;
            owl:onProperty :objProp_hasReinstatementEvent
        ]
    )
] .

:Cl_IncontestabilityPeriod owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_IncontestabilityPeriod
        [
            owl:allValuesFrom xsd:integer ;
            owl:onProperty :dataProp_durationInDaysIncontestabilityPeriod
        ]
    )
] .

:Cl_SuicideExclusionPeriod owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_SuicideExclusionPeriod
        [
            owl:allValuesFrom xsd:integer ;
            owl:onProperty :dataProp_durationInDaysSuicideExclusionPeriod
        ]
    )
] .

:Cl_GracePeriodEvent owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_GracePeriodEvent
        [
            owl:allValuesFrom xsd:integer ;
            owl:onProperty :dataProp_durationInDaysGracePeriodEvent
        ]
    )
] .

:Cl_PolicyAnniversary owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_PolicyAnniversary
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_frequencyPolicyAnniversary
        ]
    )
] .


# --- New Classes for Events from Page 3 ---
:Cl_Assignment a owl:Class ;
    rdfs:label "Assignment" ;
    rdfs:comment "The event when the Policy Owner assigns the Policy or any rights under it by written notice." ;
    rdfs:subClassOf :Cl_Event .

:Cl_Modifications a owl:Class ;
    rdfs:label "Modifications" ;
    rdfs:comment "The event when the Company modifies the Policy by issuing a change approved in writing by an executive officer." ;
    rdfs:subClassOf :Cl_Event .

:Cl_MisstatementOfAgeOrSex a owl:Class ;
    rdfs:label "Misstatement of Age or Sex" ;
    rdfs:comment "The event when the age or sex of the Insured is misstated at issue, affecting the death benefit." ;
    rdfs:subClassOf :Cl_Event .

:Cl_PolicyVoidAbInitio a owl:Class ;
    rdfs:label "Policy Void Ab Initio" ;
    rdfs:comment "The event when the Policy is voided from the beginning due to the Insured being outside of an insurable age range." ;
    rdfs:subClassOf :Cl_Event .

:Cl_ChangeBeneficiary a owl:Class ;
    rdfs:label "Change Beneficiary" ;
    rdfs:comment "The event when the Policy Owner exercises the right to change the Beneficiary." ;
    rdfs:subClassOf :Cl_Event .

:Cl_PolicyOwnerRights a owl:Class ;
    rdfs:label "Policy Owner Rights" ;
    rdfs:comment "The event when the Policy Owner exercises contractual rights such as changing the beneficiary, assigning the policy, or electing optional forms of benefits." ;
    rdfs:subClassOf :Cl_Event .

# --- New Object Properties for Event Participants ---
:objProp_hasAssignmentEvent a owl:ObjectProperty ;
    rdfs:label "hasAssignmentEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Assignment .

:objProp_hasModificationsEvent a owl:ObjectProperty ;
    rdfs:label "hasModificationsEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Modifications .

:objProp_hasMisstatementEvent a owl:ObjectProperty ;
    rdfs:label "hasMisstatementEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_MisstatementOfAgeOrSex .

:objProp_hasVoidAbInitioEvent a owl:ObjectProperty ;
    rdfs:label "hasVoidAbInitioEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyVoidAbInitio .

:objProp_hasChangeBeneficiaryEvent a owl:ObjectProperty ;
    rdfs:label "hasChangeBeneficiaryEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_ChangeBeneficiary .

:objProp_hasPolicyOwnerRightsEvent a owl:ObjectProperty ;
    rdfs:label "hasPolicyOwnerRightsEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyOwnerRights .

:objProp_participatesInAssignment a owl:ObjectProperty ;
    rdfs:label "participatesInAssignment" ;
    rdfs:domain :Cl_PolicyOwner ;
    rdfs:range :Cl_Assignment .

:objProp_participatesInModifications a owl:ObjectProperty ;
    rdfs:label "participatesInModifications" ;
    rdfs:domain :Cl_Company ;
    rdfs:range :Cl_Modifications .

:objProp_participatesInMisstatement a owl:ObjectProperty ;
    rdfs:label "participatesInMisstatement" ;
    rdfs:domain :Cl_InsuredPerson ;
    rdfs:range :Cl_MisstatementOfAgeOrSex .

:objProp_participatesInPolicyVoidAbInitio a owl:ObjectProperty ;
    rdfs:label "participatesInPolicyVoidAbInitio" ;
    rdfs:domain :Cl_InsuredPerson ;
    rdfs:range :Cl_PolicyVoidAbInitio .

:objProp_participatesInChangeBeneficiary a owl:ObjectProperty ;
    rdfs:label "participatesInChangeBeneficiary" ;
    rdfs:domain :Cl_PolicyOwner ;
    rdfs:range :Cl_ChangeBeneficiary .

:objProp_participatesInPolicyOwnerRights a owl:ObjectProperty ;

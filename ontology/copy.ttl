    owl:intersectionOf (
        :Cl_PolicyRestoration
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_participatesInPolicyRestoration
        ]
    )
] .


# --- New Classes for Page 5: Death Benefit and Related Events ---
:Cl_DeathBenefit a owl:Class ;
    rdfs:label "Death Benefit" ;
    rdfs:comment "The event when the death benefit is paid to the designated beneficiary upon the insured's death." ;
    rdfs:subClassOf :Cl_Event .

:Cl_ProofOfDeath a owl:Class ;
    rdfs:label "Proof of Death" ;
    rdfs:comment "The event when the company requires documentation to verify the insured's death." ;
    rdfs:subClassOf :Cl_Event .

:Cl_PaymentOfProceeds a owl:Class ;
    rdfs:label "Payment of Proceeds" ;
    rdfs:comment "The event when the death benefit proceeds are paid to the beneficiary or estate." ;
    rdfs:subClassOf :Cl_Event .

:Cl_InterestOnDeathBenefit a owl:Class ;
    rdfs:label "Interest on Death Benefit" ;
    rdfs:comment "The event when interest accrues on the death benefit from the date of death to the date of payment." ;
    rdfs:subClassOf :Cl_Event .

:Cl_ContingentBeneficiaryConsideration a owl:Class ;
    rdfs:label "Contingent Beneficiary Consideration" ;
    rdfs:comment "The event when the policy considers the contingent beneficiary or the estate as the recipient if the primary beneficiary does not survive." ;
    rdfs:subClassOf :Cl_Event .

:Cl_SimultaneousDeathAssumption a owl:Class ;
    rdfs:label "Simultaneous Death Assumption" ;
    rdfs:comment "The event when the company assumes the beneficiary predeceased the insured in the case of simultaneous death." ;
    rdfs:subClassOf :Cl_Event .


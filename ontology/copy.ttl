    owl:intersectionOf (
        :Cl_LapseForNonpayment
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_participatesInLapseForNonpayment
        ]
    )
] .

:Cl_ReinstatementEvent owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_ReinstatementEvent
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredMannerReinstatement
        ]
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredMannerEvidenceOfInsurability
        ]
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredMannerOverduePremiums
        ]
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_participatesInReinstatementEvent
        ]
    )
] .

:Cl_ReinstatementPeriodInterval owl:equivalentClass [
    a owl:Class ;

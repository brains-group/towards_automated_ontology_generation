@prefix : <http://www.example.org/test#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Classes ---

:Cl_Policy a owl:Class ;
    rdfs:label "Policy" ;
    rdfs:comment "A life insurance policy issued by Equivita Mutual Life Insurance Company." .

:Cl_PolicyOwner a owl:Class ;
    rdfs:label "Policy Owner" ;
    rdfs:comment "The individual or entity that owns the insurance policy." .

:Cl_InsuredPerson a owl:Class ;
    rdfs:label "Insured Person" ;
    rdfs:comment "The person whose life is covered by the insurance policy." .

:Cl_Beneficiary a owl:Class ;
    rdfs:label "Beneficiary" ;
    rdfs:comment "The person designated to receive the death benefit upon the insured's death." .

:Cl_PolicyType a owl:Class ;
    rdfs:label "Policy Type" ;
    rdfs:comment "The type of life insurance policy, such as Term or Whole Life." .

:Cl_Event a owl:Class ;
    rdfs:label "Event" ;
    rdfs:comment "A significant occurrence in the lifecycle of a policy." .

:Cl_Cancellation a owl:Class ;
    rdfs:label "Cancellation" ;
    rdfs:comment "An event where a policy is terminated at the request of the policy owner." ;
    rdfs:subClassOf :Cl_Event .

:Cl_ReinstatementPeriod a owl:Class ;
    rdfs:label "Reinstatement Period" ;
    rdfs:comment "A time interval during which a lapsed policy can be reinstated." ;
    rdfs:subClassOf :Cl_Event .

:Cl_PolicyState a owl:Class ;
    rdfs:label "Policy State" ;
    rdfs:comment "The current status of a policy, such as Active, In Grace Period, or Lapsed." .

:Cl_GracePeriod a owl:Class ;
    rdfs:label "Grace Period" ;
    rdfs:comment "A period after a premium is due during which the policy remains active." ;
    rdfs:subClassOf :Cl_Event .

:Cl_LapsedPolicy a owl:Class ;
    rdfs:label "Lapsed Policy" ;
    rdfs:comment "A policy that has expired due to non-payment of premiums." ;
    rdfs:subClassOf :Cl_Event .

# --- Object Properties ---

:objProp_hasOwner a owl:ObjectProperty ;
    rdfs:label "hasOwner" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyOwner .

:objProp_hasInsured a owl:ObjectProperty ;
    rdfs:label "hasInsured" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_InsuredPerson .

:objProp_hasBeneficiary a owl:ObjectProperty ;
    rdfs:label "hasBeneficiary" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Beneficiary .

:objProp_hasPolicyType a owl:ObjectProperty ;
    rdfs:label "hasPolicyType" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyType .

:objProp_participatesIn a owl:ObjectProperty ;
    rdfs:label "participatesIn" ;
    rdfs:domain :Cl_PolicyOwner ;
    rdfs:range :Cl_Event .

:objProp_hasEvent a owl:ObjectProperty ;
    rdfs:label "hasEvent" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Event .
:objProp_isInitiatedBy a owl:ObjectProperty ;
    rdfs:label "isInitiatedBy" ;
    rdfs:domain :Cl_Cancellation ;
    rdfs:range :Cl_PolicyOwner .

:objProp_hasInitiationMethod a owl:ObjectProperty ;
    rdfs:label "hasInitiationMethod" ;
    rdfs:domain :Cl_Cancellation ;
    rdfs:range :Cl_InitiationMethod .

:objProp_hasReinstatementPeriod a owl:ObjectProperty ;
    rdfs:label "hasReinstatementPeriod" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_ReinstatementPeriod .

:objProp_hasGracePeriod a owl:ObjectProperty ;
    rdfs:label "hasGracePeriod" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_GracePeriod .

:objProp_hasLapsedState a owl:ObjectProperty ;
    rdfs:label "hasLapsedState" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_LapsedPolicy .

:objProp_hasState a owl:ObjectProperty ;
    rdfs:label "hasState" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyState .
# --- Data Properties ---

:dataProp_faceAmount a owl:DatatypeProperty ;
    rdfs:label "faceAmount" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:decimal .

:dataProp_currencyUnit a owl:DatatypeProperty ;
    rdfs:label "currencyUnit" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:string .

:dataProp_issueDate a owl:DatatypeProperty ;
    rdfs:label "issueDate" ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:dateTime .

:dataProp_durationInDays a owl:DatatypeProperty ;
    rdfs:label "durationInDays" ;
    rdfs:domain :Cl_ReinstatementPeriod ;
    rdfs:range xsd:integer .

:dataProp_durationInDaysGracePeriod a owl:DatatypeProperty ;
    rdfs:label "durationInDaysGracePeriod" ;
    rdfs:domain :Cl_GracePeriod ;
    rdfs:range xsd:integer .

:dataProp_eventStart a owl:DatatypeProperty ;
    rdfs:label "eventStart" ;
    rdfs:domain :Cl_Event ;
    rdfs:range xsd:dateTime .

:dataProp_eventEnd a owl:DatatypeProperty ;
    rdfs:label "eventEnd" ;
    rdfs:domain :Cl_Event ;
    rdfs:range xsd:dateTime .

# --- Individuals ---

:ind_Policy_EML202500028391 a :Cl_Policy ;
    :objProp_hasOwner :ind_PolicyOwner_JordanEllis ;
    :objProp_hasInsured :ind_InsuredPerson_JordanEllis ;

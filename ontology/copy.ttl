# --- New Restrictions for Event Properties ---
:Cl_Policy owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Policy
        [
            owl:allValuesFrom :Cl_Assignment ;
            owl:onProperty :objProp_hasAssignmentEvent
        ]
        [
            owl:allValuesFrom :Cl_Modifications ;
            owl:onProperty :objProp_hasModificationsEvent
        ]
        [
            owl:allValuesFrom :Cl_MisstatementOfAgeOrSex ;
            owl:onProperty :objProp_hasMisstatementEvent
        ]
        [
            owl:allValuesFrom :Cl_PolicyVoidAbInitio ;
            owl:onProperty :objProp_hasVoidAbInitioEvent
        ]
        [
            owl:allValuesFrom :Cl_ChangeBeneficiary ;
            owl:onProperty :objProp_hasChangeBeneficiaryEvent
        ]
        [
            owl:allValuesFrom :Cl_PolicyOwnerRights ;
            owl:onProperty :objProp_hasPolicyOwnerRightsEvent
        ]
    )
] .

:Cl_Assignment owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Assignment
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredManner
        ]
    )
] .

:Cl_Modifications owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_Modifications
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_requiredMannerModifications
        ]
    )
] .

:Cl_MisstatementOfAgeOrSex owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_MisstatementOfAgeOrSex
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_effectOnDeathBenefit
        ]
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_effectOnPremiums
        ]
    )
] .

:Cl_PolicyVoidAbInitio owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_PolicyVoidAbInitio
        [
            owl:allValuesFrom xsd:string ;
            owl:onProperty :dataProp_effectOnPremiums
        ]
    )
] .

:Cl_ChangeBeneficiary owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_ChangeBeneficiary
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_participatesInChangeBeneficiary
        ]
    )
] .

:Cl_PolicyOwnerRights owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Cl_PolicyOwnerRights
        [
            owl:allValuesFrom :Cl_PolicyOwner ;
            owl:onProperty :objProp_participatesInPolicyOwnerRights
        ]
    )
] .


# --- New Classes for Page 4: Premiums and Grace Period ---
:Cl_PremiumPayment a owl:Class ;
    rdfs:label "Premium Payment" ;
    rdfs:comment "The event when a premium is paid for the policy." ;
    rdfs:subClassOf :Cl_Event .

:Cl_PremiumNotPaid a owl:Class ;
    rdfs:label "Premium Not Paid" ;
    rdfs:comment "The event when a premium payment is delayed beyond the due date." ;
    rdfs:subClassOf :Cl_Event .

:Cl_GracePeriodEvent a owl:Class ;
    rdfs:label "Grace Period Event" ;
    rdfs:comment "The event when a policy remains in force after a premium due date during which the policy remains in force." ;
    rdfs:subClassOf :Cl_Event .

:Cl_LapseForNonpayment a owl:Class ;
    rdfs:label "Lapse for Nonpayment" ;
    rdfs:comment "The event when a policy lapses due to nonpayment of premium after the grace period." ;
    rdfs:subClassOf :Cl_Event .

:Cl_ReinstatementEvent a owl:Class ;
    rdfs:label "Reinstatement Event" ;
    rdfs:comment "The event when a lapsed policy is restored to active status." ;
    rdfs:subClassOf :Cl_Event .

:Cl_ReinstatementPeriodInterval a owl:Class ;
    rdfs:label "Reinstatement Period Interval" ;
    rdfs:comment "The time interval during which a lapsed policy can be reinstated." ;
    rdfs:subClassOf :Cl_Event .

:Cl_PolicyTermination a owl:Class ;
    rdfs:label "Policy Termination" ;
    rdfs:comment "The event when a policy's coverage is terminated at the owner's request." ;
    rdfs:subClassOf :Cl_Event .

:Cl_PolicyRestoration a owl:Class ;
    rdfs:label "Policy Restoration" ;
    rdfs:comment "The event when a policy's coverage is restored after lapsing." ;
    rdfs:subClassOf :Cl_Event .



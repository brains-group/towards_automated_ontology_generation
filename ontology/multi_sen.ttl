### Instantiation of Facts from Contract
:Policy_001 a :Cl_Policy ;
    :hasFaceAmount 500000 ;
    :hasCurrencyUnit "USD" ;
    :hasCoverageTermStart "2025-08-07"^^xsd:date ;
    :hasCoverageTermEnd "2045-08-07"^^xsd:date ;
    :hasReinstatementPeriod :ReinstatementPeriod_001 ;
    :hasGracePeriodDuration :GracePeriodDuration_001 .

:CoverageTermination_001 a :Cl_CoverageTermination ;
    :hasEvent :Event_Cancellation ;
    :hasAgentRole :AgentRole_PolicyOwner ;
    :hasObjectRole :ObjectRole_Policy ;
    :hasManner :CancellationManner .

:Event_Cancellation a :Cl_Event ;
    :hasName "Cancellation" .

:AgentRole_PolicyOwner a :Cl_AgentRole ;
    :hasName "Policy Owner" .

:ObjectRole_Policy a :Cl_ObjectRole ;
    :hasName "Policy" .

:CancellationManner a :Cl_TemporalExtent ;
    :hasValue "written notice" ;
    :hasDurationValue "P0D" .

:ReinstatementPeriod_001 a :Cl_TemporalExtent ;
    :hasValue "5 years" ;
    :hasDurationValue "P5Y" .

:GracePeriodDuration_001 a :Cl_TemporalExtent ;
    :hasValue "31 days" ;
    :hasDurationValue "P31D" .

### State Transition for Grace Period
:Transition_GracePeriod a :Cl_StateTransition ;
    :hasFromState :Cl_PolicyState_Active ;
    :hasToState :Cl_PolicyState_GracePeriod ;
    :hasTrigger :Reification_GracePeriodTrigger ;
    :hasGuard :Reification_GracePeriodGuard .

:Reification_GracePeriodTrigger a :Cl_PropertyReification ;
    :hasName "Missed premium payment" ;
    :hasCondition "Premium payment is overdue" .

:Reification_GracePeriodGuard a :Cl_PropertyReification ;
    :hasName "Grace period not expired" ;
    :hasCondition "Grace period has not ended" .

### State Transition for Reinstatement
:Transition_Reinstated a :Cl_StateTransition ;
    :hasFromState :Cl_PolicyState_Lapse ;
    :hasToState :Cl_PolicyState_Reinstated ;
    :hasTrigger :Reification_ReinstatementTrigger ;
    :hasGuard :Reification_ReinstatementGuard .

:Reification_ReinstatementTrigger a :Cl_PropertyReification ;
    :hasName "Reinstatement request submitted" ;
    :hasCondition "Policyholder submits reinstatement request" .

:Reification_ReinstatementGuard a :Cl_PropertyReification ;
    :hasName "Within reinstatement period" ;
    :hasCondition "Reinstatement request is made within 5 years of lapse" .

### State Transition for Cancellation
:Transition_Cancellation a :Cl_StateTransition ;
    :hasFromState :Cl_PolicyState_Active ;
    :hasToState :Cl_PolicyState_Lapse ;
    :hasTrigger :Reification_CancellationTrigger ;
    :hasGuard :Reification_CancellationGuard .

:Reification_CancellationTrigger a :Cl_PropertyReification ;
    :hasName "Cancellation request" ;
    :hasCondition "Policy Owner submits written notice" .

:Reification_CancellationGuard a :Cl_PropertyReification ;
    :hasName "Policy is active" ;
    :hasCondition "Policy is in Active state before cancellation" .

### Right to Examine Policy
:RightToExamine a :Cl_PropertyReification ;
    :hasName "Right to Examine" ;
    :hasCondition "Policyholder examines policy within 20 days of receipt" ;
    :hasEffect "Policy is void from inception if returned within examination period" .

:ExaminationPeriod a :Cl_TemporalExtent ;
    :hasValue "20 days" ;
    :hasDurationValue "P20D" .

:ExaminationTrigger a :Cl_PropertyReification ;
    :hasName "Receipt of policy" ;
    :hasCondition "Policy is received by the Policy Owner" .

:ExaminationEffect a :Cl_PropertyReification ;
    :hasName "Void from inception" ;
    :hasCondition "Policy is returned within 20 days" ;
    :hasEffect "Policy is treated as if never issued" .
### New Classes to Create
:Cl_AcceleratedDeathBenefit a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Accelerated Death Benefit" ;
    rdfs:comment "An early payment of a portion of the Death Benefit due to a terminal illness diagnosis with a life expectancy of 12 months or less, subject to medical documentation and Company approval." .

:Cl_RequestForAcceleratedBenefit a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Request for Accelerated Benefit" ;
    rdfs:comment "A written submission by the Policyowner to initiate the process for early payment of a portion of the Death Benefit." .

:Cl_RevocationOfRequest a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Revocation of Request" ;
    rdfs:comment "A written notice by the Policyowner to cancel a pending request for an accelerated benefit before payment is made." .

:Cl_PaymentOfAcceleratedBenefit a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Payment of Accelerated Benefit" ;
    rdfs:comment "The disbursement of the accelerated benefit amount to the Policyowner." .

:Cl_ReducedDeathBenefit a owl:Class ;
    rdfs:subClassOf :Cl_State ;
    rdfs:label "Reduced Death Benefit" ;
    rdfs:comment "The updated Death Benefit amount after deduction of the accelerated benefit, administrative charges, and outstanding loans." .

:Cl_ExclusionEvent a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Exclusion Event" ;
    rdfs:comment "An event that disqualifies the Insured from receiving an accelerated benefit, such as terminal illness due to intentional self-inflicted injury, felony participation, or war-related activities." .

:Cl_TerminalIllness a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Terminal Illness" ;
    rdfs:comment "A diagnosis of a condition with a life expectancy of 12 months or less, as certified by a licensed physician." .

:Cl_SecondMedicalOpinion a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Second Medical Opinion" ;
    rdfs:comment "An independent medical review conducted by the Company to verify the terminal illness diagnosis." .

:Cl_MedicalDocumentation a owl:Class ;
    rdfs:label "Medical Documentation" ;
    rdfs:comment "Evidence acceptable to the Company to support a terminal illness diagnosis." .

### Object Properties
:requires a owl:ObjectProperty ;
    rdfs:domain :Cl_AcceleratedDeathBenefit ;
    rdfs:range :Cl_TerminalIllness ;
    rdfs:label "requires" ;
    rdfs:comment "Indicates that the Accelerated Death Benefit requires a Terminal Illness diagnosis." .

:reduces a owl:ObjectProperty ;
    rdfs:domain :Cl_AcceleratedDeathBenefit ;
    rdfs:range :Cl_DeathBenefit ;
    rdfs:label "reduces" ;
    rdfs:comment "Indicates that the Accelerated Death Benefit reduces the Death Benefit." .

:mayBeExcludedBy a owl:ObjectProperty ;
    rdfs:domain :Cl_AcceleratedDeathBenefit ;
    rdfs:range :Cl_ExclusionEvent ;
    rdfs:label "may be excluded by" ;
    rdfs:comment "Indicates that the Accelerated Death Benefit may be excluded if an Exclusion Event occurs." .

:hasMedicalDocumentation a owl:ObjectProperty ;
    rdfs:domain :Cl_RequestForAcceleratedBenefit ;
    rdfs:range :Cl_MedicalDocumentation ;
    rdfs:label "has medical documentation" ;
    rdfs:comment "Relates a request to the medical documentation submitted." .

:revokes a owl:ObjectProperty ;
    rdfs:domain :Cl_RevocationOfRequest ;
    rdfs:range :Cl_RequestForAcceleratedBenefit ;
    rdfs:label "revokes" ;
    rdfs:comment "Indicates that a revocation cancels a prior request." .

:triggers a owl:ObjectProperty ;
    rdfs:domain :Cl_RequestForAcceleratedBenefit ;
    rdfs:range :Cl_StateTransition ;
    rdfs:label "triggers" ;
    rdfs:comment "Indicates that a request triggers a state transition." .

:triggers a owl:ObjectProperty ;
    rdfs:domain :Cl_RevocationOfRequest ;
    rdfs:range :Cl_StateTransition ;
    rdfs:label "triggers" ;
    rdfs:comment "Indicates that a revocation triggers a state transition." .

:isResultOf a owl:ObjectProperty ;
    rdfs:domain :Cl_ReducedDeathBenefit ;
    rdfs:range :Cl_PaymentOfAcceleratedBenefit ;
    rdfs:label "is result of" ;
    rdfs:comment "Indicates that the reduced death benefit is the result of a payment." .

:reducedBy a owl:ObjectProperty ;
    rdfs:domain :Cl_ReducedDeathBenefit ;
    rdfs:range :Cl_DeathBenefit ;
    rdfs:label "reduced by" ;
    rdfs:comment "Indicates that the reduced death benefit is reduced from the original death benefit." .

:hasAmountPaid a owl:ObjectProperty ;
    rdfs:domain :Cl_PaymentOfAcceleratedBenefit ;
    rdfs:range :Cl_MonetaryAmount ;
    rdfs:label "has amount paid" ;
    rdfs:comment "Relates the payment to the amount paid." .

:hasAdministrativeCharges a owl:ObjectProperty ;
    rdfs:domain :Cl_PaymentOfAcceleratedBenefit ;
    rdfs:range :Cl_MonetaryAmount ;
    rdfs:label "has administrative charges" ;
    rdfs:comment "Relates the payment to the administrative charges applied." .

:hasOutstandingLoans a owl:ObjectProperty ;
    rdfs:domain :Cl_PaymentOfAcceleratedBenefit ;
    rdfs:range :Cl_MonetaryAmount ;
    rdfs:label "has outstanding loans" ;
    rdfs:comment "Relates the payment to the outstanding loans deducted." .

### Data Properties
:hasMaximumPercentage a owl:DatatypeProperty ;
    rdfs:domain :Cl_AcceleratedDeathBenefit ;
    rdfs:range xsd:decimal ;
    rdfs:label "has maximum percentage" ;
    rdfs:comment "The maximum percentage of the policy’s Face Amount that can be paid under the Accelerated Death Benefit (50%)." .

:hasMaximumLimit a owl:DatatypeProperty ;
    rdfs:domain :Cl_AcceleratedDeathBenefit ;
    rdfs:range xsd:decimal ;
    rdfs:label "has maximum limit" ;
    rdfs:comment "The maximum monetary limit for the Accelerated Death Benefit, determined by the Company." .

:hasLifeExpectancy a owl:DatatypeProperty ;
    rdfs:domain :Cl_TerminalIllness ;
    rdfs:range xsd:string ;
    rdfs:label "has life expectancy" ;
    rdfs:comment "The life expectancy of the Insured at the time of terminal illness diagnosis (12 months or less)." .

:hasMannerOfRequest a owl:DatatypeProperty ;
    rdfs:domain :Cl_RequestForAcceleratedBenefit ;
    rdfs:range xsd:string ;
    rdfs:label "has manner of request" ;
    rdfs:comment "The required manner for initiating a request (written request)." .

:hasMannerOfRevocation a owl:DatatypeProperty ;
    rdfs:domain :Cl_RevocationOfRequest ;
    rdfs:range xsd:string ;
    rdfs:label "has manner of revocation" ;
    rdfs:comment "The required manner for revoking a request (written notice)." .

:hasExclusionReason a owl:DatatypeProperty ;
    rdfs:domain :Cl_ExclusionEvent ;
    rdfs:range xsd:string ;
    rdfs:label "has exclusion reason" ;
    rdfs:comment "The reason for exclusion (e.g., intentional self-inflicted injury, felony, war-related activities)." .

:hasDocumentationRequirement a owl:DatatypeProperty ;
    rdfs:domain :Cl_MedicalDocumentation ;
    rdfs:range xsd:string ;
    rdfs:label "has documentation requirement" ;
    rdfs:comment "The type of medical documentation required (acceptable to the Company)." .

### Instantiation of Facts from Contract
:AcceleratedDeathBenefit_001 a :Cl_AcceleratedDeathBenefit ;
    :requires :TerminalIllness_001 ;
    :reduces :DeathBenefit_001 ;
    :mayBeExcludedBy :ExclusionEvent_001 ;
    :hasMaximumPercentage 50.0 .

:RequestForAcceleratedBenefit_001 a :Cl_RequestForAcceleratedBenefit ;
    :hasMannerOfRequest "written request" ;
    :hasMedicalDocumentation :MedicalDocumentation_001 ;
    :triggers :Transition_RequestUnderReview .

:RevocationOfRequest_001 a :Cl_RevocationOfRequest ;
    :hasMannerOfRevocation "written notice" ;
    :revokes :RequestForAcceleratedBenefit_001 ;
    :triggers :Transition_RequestRevoked .

:PaymentOfAcceleratedBenefit_001 a :Cl_PaymentOfAcceleratedBenefit ;
    :hasAmountPaid :AmountPaid_001 ;
    :hasAdministrativeCharges :AdministrativeCharges_001 ;
    :hasOutstandingLoans :OutstandingLoans_001 .

:ReducedDeathBenefit_001 a :Cl_ReducedDeathBenefit ;
    :isResultOf :PaymentOfAcceleratedBenefit_001 ;
    :reducedBy :DeathBenefit_001 .

:TerminalIllness_001 a :Cl_TerminalIllness ;
    :hasLifeExpectancy "12 months or less" .

:ExclusionEvent_001 a :Cl_ExclusionEvent ;
    :hasExclusionReason "terminal illness resulting from intentional self-inflicted injury, participation in a felony, or war-related activities" .

:MedicalDocumentation_001 a :Cl_MedicalDocumentation ;
    :hasDocumentationRequirement "medical documentation acceptable to the Company" .

:AmountPaid_001 a :Cl_MonetaryAmount ;
    :hasAmount 250000.0 ;
    :hasCurrencyUnit "USD" .

:AdministrativeCharges_001 a :Cl_MonetaryAmount ;
    :hasAmount 1000.0 ;
    :hasCurrencyUnit "USD" .

:OutstandingLoans_001 a :Cl_MonetaryAmount ;
    :hasAmount 5000.0 ;
    :hasCurrencyUnit "USD" .

:Transition_RequestUnderReview a :Cl_StateTransition ;
    :hasFromState :Cl_PolicyState_Active ;
    :hasToState :Cl_PolicyState_RequestUnderReview ;
    :hasTrigger :Reification_RequestTrigger ;
    :hasGuard :Reification_RequestGuard .

:Transition_RequestRevoked a :Cl_StateTransition ;
    :hasFromState :Cl_PolicyState_RequestUnderReview ;
    :hasToState :Cl_PolicyState_Active ;
    :hasTrigger :Reification_RevocationTrigger ;
    :hasGuard :Reification_RevocationGuard .

:Reification_RequestTrigger a :Cl_PropertyReification ;
    :hasName "Request submitted" ;
    :hasCondition "Policyowner submits written request" .

:Reification_RequestGuard a :Cl_PropertyReification ;
    :hasName "Request not yet paid" ;
    :hasCondition "Accelerated benefit has not been paid" .

:Reification_RevocationTrigger a :Cl_PropertyReification ;
    :hasName "Revocation submitted" ;
    :hasCondition "Policyowner submits written notice" .

:Reification_RevocationGuard a :Cl_PropertyReification ;
    :hasName "Request is pending" ;
    :hasCondition "Request is in 'Under Review' state" .

:Policy_001 a :Cl_Policy ;
    :hasAcceleratedBenefitAmount :AmountPaid_001 ;
    :hasReducedDeathBenefit :ReducedDeathBenefit_001 .
### New Classes to Create
:Cl_ExecutionOfPolicy a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Execution of Policy" ;
    rdfs:comment "The formal signing of the policy by Sentinel Life Assurance Company at its Home Office." .

:Cl_FraudWarning a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Fraud Warning" ;
    rdfs:comment "A legal notice warning against fraudulent insurance acts." .

:Cl_FraudulentInsuranceAct a owl:Class ;
    rdfs:subClassOf :Cl_Event ;
    rdfs:label "Fraudulent Insurance Act" ;
    rdfs:comment "An act of knowingly filing a materially false insurance application or claim with intent to defraud." .

:Cl_StateSpecificNotice a owl:Class ;
    rdfs:subClassOf :Cl_Entity ;
    rdfs:label "State Specific Notice" ;
    rdfs:comment "A legal provision or notice required by a specific state's law." .

:Cl_LivingOnEffectiveDate a owl:Class ;
    rdfs:subClassOf :Cl_State ;
    rdfs:label "Living on Effective Date" ;
    rdfs:comment "The condition that the Insured must be alive on the effective date of the policy." .

### Object Properties
:hasLocation a owl:ObjectProperty ;
    rdfs:domain :Cl_ExecutionOfPolicy ;
    rdfs:range :Cl_Location ;
    rdfs:label "has location" ;
    rdfs:comment "Relates the execution of a policy to its physical location." .

:hasConditionForEffectiveness a owl:ObjectProperty ;
    rdfs:domain :Cl_ExecutionOfPolicy ;
    rdfs:range :Cl_PropertyReification ;
    rdfs:label "has condition for effectiveness" ;
    rdfs:comment "Relates the execution event to the condition that must be met for the policy to become effective." .

:hasFraudulentAct a owl:ObjectProperty ;
    rdfs:domain :Cl_FraudWarning ;
    rdfs:range :Cl_FraudulentInsuranceAct ;
    rdfs:label "has fraudulent act" ;
    rdfs:comment "Relates a fraud warning to the specific fraudulent act it defines." .

:hasStateNotice a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_StateSpecificNotice ;
    rdfs:label "has state notice" ;
    rdfs:comment "Relates a policy to its state-specific legal notices or provisions." .

:hasEndorsement a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Endorsement ;
    rdfs:label "has endorsement" ;
    rdfs:comment "Relates a policy to its attached endorsements." .

:hasNoticePage a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_NoticePage ;
    rdfs:label "has notice page" ;
    rdfs:comment "Relates a policy to its attached state notice pages." .

:hasChiefExecutiveOfficer a owl:ObjectProperty ;
    rdfs:domain :Cl_Insurer ;
    rdfs:range :Cl_ChiefExecutiveOfficer ;
    rdfs:label "has chief executive officer" ;
    rdfs:comment "Relates an insurer to its chief executive officer." .

:hasTitle a owl:ObjectProperty ;
    rdfs:domain :Cl_AgentRole ;
    rdfs:range :Cl_NameStub ;
    rdfs:label "has title" ;
    rdfs:comment "Relates an agent role to its title." .

### Data Properties
:hasFormNumber a owl:DatatypeProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:string ;
    rdfs:label "has form number" ;
    rdfs:comment "Represents the form number of the policy, such as SLAC-TL2025-20YR." .

:hasFirstPremium a owl:DatatypeProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:decimal ;
    rdfs:label "has first premium" ;
    rdfs:comment "Represents the amount of the first premium payment." .

:hasNotice a owl:DatatypeProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:string ;
    rdfs:label "has notice" ;
    rdfs:comment "Represents any additional notice included in the policy." .

:hasLocationName a owl:DatatypeProperty ;
    rdfs:domain :Cl_Location ;
    rdfs:range xsd:string ;
    rdfs:label "has location name" ;
    rdfs:comment "Represents the name of a physical location, such as 'Hartford, Connecticut'." .

:hasChiefExecutiveName a owl:DatatypeProperty ;
    rdfs:domain :Cl_ChiefExecutiveOfficer ;
    rdfs:range xsd:string ;
    rdfs:label "has chief executive name" ;
    rdfs:comment "Represents the name of the chief executive officer." .

:hasAuthorizedRepresentativeTitle a owl:DatatypeProperty ;
    rdfs:domain :Cl_AuthorizedRepresentative ;
    rdfs:range xsd:string ;
    rdfs:label "has authorized representative title" ;
    rdfs:comment "Represents the title of the authorized representative." .

### Instantiation of Facts from Contract
:ExecutionOfPolicy_001 a :Cl_ExecutionOfPolicy ;
    :hasLocation :Location_Hartford ;
    :hasConditionForEffectiveness :Reification_EffectivenessCondition .

:Location_Hartford a :Cl_Location ;
    :hasLocationName "Hartford, Connecticut" .

:Reification_EffectivenessCondition a :Cl_PropertyReification ;
    :hasName "Policy Effectiveness Condition" ;
    :hasCondition "First premium paid and Insured is living on effective date" ;
    :hasTrigger :Reification_FirstPremiumPaid ;
    :hasGuard :Reification_LivingOnEffectiveDate .

:Reification_FirstPremiumPaid a :Cl_PropertyReification ;
    :hasName "First premium paid" ;
    :hasCondition "First premium has been paid" .

:Reification_LivingOnEffectiveDate a :Cl_PropertyReification ;
    :hasName "Insured is living on effective date" ;
    :hasCondition "Insured is alive on the effective date" .

:FraudWarning_001 a :Cl_FraudWarning ;
    :hasFraudulentAct :FraudulentInsuranceAct_001 .

:FraudulentInsuranceAct_001 a :Cl_FraudulentInsuranceAct ;
    :hasCondition "Knowingly files application with materially false information or conceals material facts with intent to defraud" .

:Policy_001 a :Cl_Policy ;
    :hasFormNumber "SLAC-TL2025-20YR" ;
    :hasFirstPremium 1000.0 ;
    :hasNotice "Additional state-specific notices or provisions as required by law. Refer to attached endorsements or state notice pages, if any." ;
    :hasStateNotice :StateNotice_001 ;
    :hasEndorsement :Endorsement_001 ;
    :hasNoticePage :NoticePage_001 .

:StateNotice_001 a :Cl_StateSpecificNotice ;
    :hasName "State Notice for New York" .

:Endorsement_001 a :Cl_Endorsement ;
    :hasName "Endorsement for California" .

:NoticePage_001 a :Cl_NoticePage ;
    :hasName "Notice Page for Texas" .

:Insurer_001 a :Cl_Insurer ;
    :hasChiefExecutiveOfficer :ChiefExecutiveOfficer_Raynor .

:ChiefExecutiveOfficer_Raynor a :Cl_ChiefExecutiveOfficer ;
    :hasChiefExecutiveName "Eleanor B. Raynor" .

:AuthorizedRepresentative_001 a :Cl_AuthorizedRepresentative ;
    :hasTitle :Title_AuthorizedRepresentative .

:Title_AuthorizedRepresentative a :Cl_NameStub ;
    :hasName "Authorized Representative" .

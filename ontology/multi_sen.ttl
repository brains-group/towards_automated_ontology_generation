@prefix : <http://www.example.org/test#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix dcterms: <http://purl.org/dc/terms/> .

# Pivot Classes for Reification
:Cl_PropertyReification a owl:Class ;
    rdfs:label "Property Reification" ;
    rdfs:comment "Reifies a property between two entities with additional metadata such as trigger, guard, or condition." .

:Cl_StateTransition a owl:Class ;
    rdfs:label "State Transition" ;
    rdfs:comment "Represents a transition between two states in a state machine, with trigger and guard conditions." .

:Cl_TemporalExtent a owl:Class ;
    rdfs:label "Temporal Extent" ;
    rdfs:comment "Represents a time interval or point in time." .

:Cl_Identifier a owl:Class ;
    rdfs:label "Identifier" ;
    rdfs:comment "Represents a unique identifier for an entity." .

:Cl_NameStub a owl:Class ;
    rdfs:label "Name Stub" ;
    rdfs:comment "Represents a name as a string literal." .

:Cl_AgentRole a owl:Class ;
    rdfs:label "Agent Role" ;
    rdfs:comment "Represents a role played by an agent in a context." .

# Reusable Base Classes
:Cl_Policy a owl:Class ;
    rdfs:label "Policy" ;
    rdfs:comment "A legal contract between the Policy Owner and the Insurer providing life insurance coverage." .

:Cl_Insured a owl:Class ;
    rdfs:label "Insured" ;
    rdfs:comment "The individual whose life is covered by the policy." .

:Cl_Beneficiary a owl:Class ;
    rdfs:label "Beneficiary" ;
    rdfs:comment "The individual designated to receive the Death Benefit upon the Insured's death." .

:Cl_PolicyOwner a owl:Class ;
    rdfs:label "Policy Owner" ;
    rdfs:comment "The individual who owns the policy and may be the same as the Insured." .

:Cl_Insurer a owl:Class ;
    rdfs:label "Insurer" ;
    rdfs:comment "The company providing the insurance coverage." .

:Cl_Premium a owl:Class ;
    rdfs:label "Premium" ;
    rdfs:comment "A payment made by the Policy Owner to maintain coverage." .

:Cl_GracePeriod a owl:Class ;
    rdfs:label "Grace Period" ;
    rdfs:comment "A period after a premium due date during which coverage remains active." .

:Cl_Lapse a owl:Class ;
    rdfs:label "Lapse" ;
    rdfs:comment "An event where coverage terminates due to non-payment of premium." .

:Cl_Reinstatement a owl:Class ;
    rdfs:label "Reinstatement" ;
    rdfs:comment "An event where a lapsed policy is restored to active status." .

:Cl_ContestabilityPeriod a owl:Class ;
    rdfs:label "Contestability Period" ;
    rdfs:comment "A period during which the insurer may contest the validity of the policy." .

:Cl_SuicideExclusion a owl:Class ;
    rdfs:label "Suicide Exclusion" ;
    rdfs:comment "An event where the Death Benefit is not paid if the Insured dies by suicide within the contestability period." .

:Cl_EffectiveDate a owl:Class ;
    rdfs:label "Effective Date" ;
    rdfs:comment "The date on which the policy becomes effective." .

:Cl_GoverningLaw a owl:Class ;
    rdfs:label "Governing Law" ;
    rdfs:comment "The legal jurisdiction that governs the contract." .

:Cl_PolicyType a owl:Class ;
    rdfs:label "Policy Type" ;
    rdfs:comment "The type of life insurance policy, such as term or whole life." .

# New Classes to Create
:Cl_PolicyState a owl:Class ;
    rdfs:label "Policy State" ;
    rdfs:comment "Represents the current state of a policy in its lifecycle." .

:Cl_PolicyState_Active a owl:Class ;
    rdfs:subClassOf :Cl_PolicyState ;
    rdfs:label "Active" ;
    rdfs:comment "The policy is currently in force and coverage is active." .

:Cl_PolicyState_GracePeriod a owl:Class ;
    rdfs:subClassOf :Cl_PolicyState ;
    rdfs:label "Grace Period" ;
    rdfs:comment "The policy is in a grace period after a premium due date." .

:Cl_PolicyState_Lapse a owl:Class ;
    rdfs:subClassOf :Cl_PolicyState ;
    rdfs:label "Lapse" ;
    rdfs:comment "The policy has lapsed due to non-payment of premium." .

:Cl_PolicyState_Reinstated a owl:Class ;
    rdfs:subClassOf :Cl_PolicyState ;
    rdfs:label "Reinstated" ;
    rdfs:comment "The policy has been reinstated after lapsing." .

# Object Properties
:hasOwner a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyOwner ;
    rdfs:label "has owner" ;
    rdfs:comment "Relates a policy to its owner." .

:covers a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Insured ;
    rdfs:label "covers" ;
    rdfs:comment "Relates a policy to the individual it covers." .

:pays a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Beneficiary ;
    rdfs:label "pays" ;
    rdfs:comment "Relates a policy to the beneficiary it pays upon death." .

:isGovernedBy a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_GoverningLaw ;
    rdfs:label "is governed by" ;
    rdfs:comment "Relates a policy to the governing law." .

:hasDuration a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_TemporalExtent ;
    rdfs:label "has duration" ;
    rdfs:comment "Relates a policy to its duration." .

:hasContestabilityPeriod a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_ContestabilityPeriod ;
    rdfs:label "has contestability period" ;
    rdfs:comment "Relates a policy to its contestability period." .

:hasState a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyState ;
    rdfs:label "has state" ;
    rdfs:comment "Relates a policy to its current state." .

:hasEffectiveDate a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_EffectiveDate ;
    rdfs:label "has effective date" ;
    rdfs:comment "Relates a policy to its effective date." .

:hasPolicyType a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_PolicyType ;
    rdfs:label "has policy type" ;
    rdfs:comment "Relates a policy to its type." .

:hasInsurer a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Insurer ;
    rdfs:label "has insurer" ;
    rdfs:comment "Relates a policy to the insurer." .

:hasIdentifier a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_Identifier ;
    rdfs:label "has identifier" ;
    rdfs:comment "Relates a policy to its unique identifier." .

:hasTrigger a owl:ObjectProperty ;
    rdfs:domain :Cl_StateTransition ;
    rdfs:range :Cl_PropertyReification ;
    rdfs:label "has trigger" ;
    rdfs:comment "Relates a state transition to the property reification that triggers it." .

:hasGuard a owl:ObjectProperty ;
    rdfs:domain :Cl_StateTransition ;
    rdfs:range :Cl_PropertyReification ;
    rdfs:label "has guard" ;
    rdfs:comment "Relates a state transition to the property reification that acts as a guard." .

:hasFromState a owl:ObjectProperty ;
    rdfs:domain :Cl_StateTransition ;
    rdfs:range :Cl_PolicyState ;
    rdfs:label "has from state" ;
    rdfs:comment "Relates a state transition to its starting state." .

:hasToState a owl:ObjectProperty ;
    rdfs:domain :Cl_StateTransition ;
    rdfs:range :Cl_PolicyState ;
    rdfs:label "has to state" ;
    rdfs:comment "Relates a state transition to its target state." .

# Data Properties
:hasName a owl:DatatypeProperty ;
    rdfs:domain :Cl_NameStub ;
    rdfs:range xsd:string ;
    rdfs:label "has name" ;
    rdfs:comment "Represents the name of an entity as a string." .

:hasValue a owl:DatatypeProperty ;
    rdfs:domain :Cl_TemporalExtent ;
    rdfs:range xsd:string ;
    rdfs:label "has value" ;
    rdfs:comment "Represents the value of a temporal extent, such as a date or duration." .

:hasDurationValue a owl:DatatypeProperty ;
    rdfs:domain :Cl_TemporalExtent ;
    rdfs:range xsd:string ;
    rdfs:label "has duration value" ;
    rdfs:comment "Represents the duration of a time interval in ISO 8601 format." .

:hasLawText a owl:DatatypeProperty ;
    rdfs:domain :Cl_GoverningLaw ;
    rdfs:range xsd:string ;
    rdfs:label "has law text" ;
    rdfs:comment "Represents the text of the governing law." .

:hasPolicyNumber a owl:DatatypeProperty ;
    rdfs:domain :Cl_Identifier ;
    rdfs:range xsd:string ;
    rdfs:label "has policy number" ;
    rdfs:comment "Represents the unique policy number." .

:hasPremiumAmount a owl:DatatypeProperty ;
    rdfs:domain :Cl_Premium ;
    rdfs:range xsd:decimal ;
    rdfs:label "has premium amount" ;
    rdfs:comment "Represents the amount of a premium payment." .

:hasDate a owl:DatatypeProperty ;
    rdfs:domain :Cl_EffectiveDate ;
    rdfs:range xsd:date ;
    rdfs:label "has date" ;
    rdfs:comment "Represents the date of an event or point in time." .

:hasType a owl:DatatypeProperty ;
    rdfs:domain :Cl_PolicyType ;
    rdfs:range xsd:string ;
    rdfs:label "has type" ;
    rdfs:comment "Represents the type of policy." .

# Instantiation of Facts from Contract
:Policy_001 a :Cl_Policy ;
    :hasIdentifier :Identifier_001 ;
    :hasOwner :PolicyOwner_001 ;
    :covers :Insured_001 ;
    :pays :Beneficiary_001 ;
    :isGovernedBy :GoverningLaw_001 ;
    :hasDuration :Duration_001 ;
    :hasContestabilityPeriod :ContestabilityPeriod_001 ;
    :hasState :Cl_PolicyState_Active ;
    :hasEffectiveDate :EffectiveDate_001 ;
    :hasPolicyType :PolicyType_001 ;
    :hasInsurer :Insurer_001 .

:Identifier_001 a :Cl_Identifier ;
    :hasPolicyNumber "SLAC-2025-001" .

:PolicyOwner_001 a :Cl_PolicyOwner ;
    :hasName "Jordan Everett Hughes" .

:Insured_001 a :Cl_Insured ;
    :hasName "Jordan Everett Hughes" .

:Beneficiary_001 a :Cl_Beneficiary ;
    :hasName "Jordan Everett Hughes" .

:GoverningLaw_001 a :Cl_GoverningLaw ;
    :hasLawText "The contract shall be governed by and construed in accordance with the laws of the State of Colorado." .

:Duration_001 a :Cl_TemporalExtent ;
    :hasValue "20 years" ;
    :hasDurationValue "P20Y" .

:ContestabilityPeriod_001 a :Cl_ContestabilityPeriod ;
    :hasDurationValue "P2Y" .

:EffectiveDate_001 a :Cl_EffectiveDate ;
    :hasDate "2025-08-07"^^xsd:date .

:PolicyType_001 a :Cl_PolicyType ;
    :hasType "Level Term Life Insurance – 20 Years" .

:Insurer_001 a :Cl_Insurer ;
    :hasName "Sentinel Life Assurance Company" .

# State Transition for Lapse
:Transition_Lapse a :Cl_StateTransition ;
    :hasFromState :Cl_PolicyState_Active ;
    :hasToState :Cl_PolicyState_Lapse ;
    :hasTrigger :Reification_LapseTrigger ;
    :hasGuard :Reification_LapseGuard .

:Reification_LapseTrigger a :Cl_PropertyReification ;
    :hasName "Premium not paid" ;
    :hasCondition "Premium payment overdue" .

:Reification_LapseGuard a :Cl_PropertyReification ;
    :hasName "Grace period expired" ;
    :hasCondition "Grace period has ended without payment" .

# Suicide Exclusion Event
:SuicideExclusion_001 a :Cl_SuicideExclusion ;
    :hasCondition "Insured dies by suicide within contestability period" ;
    :appliesWhen :ContestabilityPeriod_001 .

# Reification for Contestability Period
:Reification_Contestability a :Cl_PropertyReification ;
    :hasName "Contestability Period" ;
    :hasDurationValue "P2Y" .
### New Classes to Create
:Cl_CoverageTermination a owl:Class ;
    rdfs:label "Coverage Termination" ;
    rdfs:comment "An event marking the end of the policy's coverage term." .

:Cl_Event a owl:Class ;
    rdfs:label "Event" ;
    rdfs:comment "A general class for events in the policy lifecycle." .

:Cl_PolicyState_Reinstated a owl:Class ;
    rdfs:subClassOf :Cl_PolicyState ;
    rdfs:label "Reinstated" ;
    rdfs:comment "The policy has been reinstated after lapsing." .

:Cl_PolicyState_GracePeriod a owl:Class ;
    rdfs:subClassOf :Cl_PolicyState ;
    rdfs:label "Grace Period" ;
    rdfs:comment "The policy is in a grace period after a premium due date." .

:Cl_TemporalExtent a owl:Class ;
    rdfs:subClassOf :Cl_TemporalExtent ;
    rdfs:label "Temporal Extent" ;
    rdfs:comment "Represents a time interval or point in time." .

# Object Properties
:hasEvent a owl:ObjectProperty ;
    rdfs:domain :Cl_CoverageTermination ;
    rdfs:range :Cl_Event ;
    rdfs:label "has event" ;
    rdfs:comment "Relates a coverage termination to its event." .

:hasAgentRole a owl:ObjectProperty ;
    rdfs:domain :Cl_CoverageTermination ;
    rdfs:range :Cl_AgentRole ;
    rdfs:label "has agent role" ;
    rdfs:comment "Relates a coverage termination to the agent participant." .

:hasObjectRole a owl:ObjectProperty ;
    rdfs:domain :Cl_CoverageTermination ;
    rdfs:range :Cl_AgentRole ;
    rdfs:label "has object role" ;
    rdfs:comment "Relates a coverage termination to the object participant." .

:hasManner a owl:ObjectProperty ;
    rdfs:domain :Cl_CoverageTermination ;
    rdfs:range :Cl_TemporalExtent ;
    rdfs:label "has manner" ;
    rdfs:comment "Relates a coverage termination to the condition that triggers it." .

:hasReinstatementPeriod a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_TemporalExtent ;
    rdfs:label "has reinstatement period" ;
    rdfs:comment "Relates a policy to its reinstatement period." .

:hasGracePeriodDuration a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_TemporalExtent ;
    rdfs:label "has grace period duration" ;
    rdfs:comment "Relates a policy to its grace period duration." .

# Data Properties
:hasFaceAmount a owl:DatatypeProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:decimal ;
    rdfs:label "has face amount" ;
    rdfs:comment "Represents the monetary value of the policy's death benefit." .

:hasCurrencyUnit a owl:DatatypeProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:string ;
    rdfs:label "has currency unit" ;
    rdfs:comment "Represents the currency of the face amount." .

:hasCoverageTermStart a owl:DatatypeProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:date ;
    rdfs:label "has coverage term start" ;
    rdfs:comment "Represents the start date of the coverage term." .

:hasCoverageTermEnd a owl:DatatypeProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:date ;
    rdfs:label "has coverage term end" ;
    rdfs:comment "Represents the end date of the coverage term." .

# Instantiation of Facts from Contract
:Policy_001 a :Cl_Policy ;
    :hasFaceAmount 500000 ;
    :hasCurrencyUnit "USD" ;
    :hasCoverageTermStart "2025-08-07"^^xsd:date ;
    :hasCoverageTermEnd "2045-08-07"^^xsd:date ;
    :hasReinstatementPeriod :ReinstatementPeriod_001 ;
    :hasGracePeriodDuration :GracePeriodDuration_001 .

:CoverageTermination_001 a :Cl_CoverageTermination ;
    :hasEvent :Event_CoverageTermination ;
    :hasAgentRole :AgentRole_Policy ;
    :hasObjectRole :ObjectRole_Policy ;
    :hasManner :CoverageTerm_001 .

:Event_CoverageTermination a :Cl_Event ;
    :hasName "Coverage Termination" .

:AgentRole_Policy a :Cl_AgentRole ;
    :hasName "Policy" .

:ObjectRole_Policy a :Cl_AgentRole ;
    :hasName "Policy" .

:CoverageTerm_001 a :Cl_TemporalExtent ;
    :hasValue "20 years" ;
    :hasDurationValue "P20Y" .

:ReinstatementPeriod_001 a :Cl_TemporalExtent ;
    :hasValue "5 years" ;
    :hasDurationValue "P5Y" .

:GracePeriodDuration_001 a :Cl_TemporalExtent ;
    :hasValue "31 days" ;
    :hasDurationValue "P31D" .

# State Transition for Grace Period
:Transition_GracePeriod a :Cl_StateTransition ;
    :hasFromState :Cl_PolicyState_Active ;
    :hasToState :Cl_PolicyState_GracePeriod ;
    :hasTrigger :Reification_GracePeriodTrigger ;
    :hasGuard :Reification_GracePeriodGuard .

:Reification_GracePeriodTrigger a :Cl_PropertyReification ;
    :hasName "Missed premium payment" ;
    :hasCondition "Premium payment is overdue" .

:Reification_GracePeriodGuard a :Cl_PropertyReification ;
    :hasName "Grace period not expired" ;
    :hasCondition "Grace period has not ended" .

# State Transition for Reinstatement
:Transition_Reinstated a :Cl_StateTransition ;
    :hasFromState :Cl_PolicyState_Lapse ;
    :hasToState :Cl_PolicyState_Reinstated ;
    :hasTrigger :Reification_ReinstatementTrigger ;
    :hasGuard :Reification_ReinstatementGuard .

:Reification_ReinstatementTrigger a :Cl_PropertyReification ;
    :hasName "Reinstatement request submitted" ;
    :hasCondition "Policyholder submits reinstatement request" .

:Reification_ReinstatementGuard a :Cl_PropertyReification ;
    :hasName "Within reinstatement period" ;
    :hasCondition "Reinstatement request is made within 5 years of lapse" .
### New Classes to Create
:Cl_CoverageTermination a owl:Class ;
    rdfs:label "Coverage Termination" ;
    rdfs:comment "An event marking the end of the policy's coverage term." .

:Cl_Event a owl:Class ;
    rdfs:label "Event" ;
    rdfs:comment "A general class for events in the policy lifecycle." .

:Cl_AgentRole a owl:Class ;
    rdfs:label "Agent Role" ;
    rdfs:comment "Represents a role played by an agent in a context." .

:Cl_ObjectRole a owl:Class ;
    rdfs:label "Object Role" ;
    rdfs:comment "Represents a role played by an object in a context." .

:Cl_PropertyReification a owl:Class ;
    rdfs:label "Property Reification" ;
    rdfs:comment "Reifies a property between two entities with additional metadata such as trigger, guard, or condition." .

### Object Properties
:hasEvent a owl:ObjectProperty ;
    rdfs:domain :Cl_CoverageTermination ;
    rdfs:range :Cl_Event ;
    rdfs:label "has event" ;
    rdfs:comment "Relates a coverage termination to its event." .

:hasAgentRole a owl:ObjectProperty ;
    rdfs:domain :Cl_CoverageTermination ;
    rdfs:range :Cl_AgentRole ;
    rdfs:label "has agent role" ;
    rdfs:comment "Relates a coverage termination to the agent participant." .

:hasObjectRole a owl:ObjectProperty ;
    rdfs:domain :Cl_CoverageTermination ;
    rdfs:range :Cl_ObjectRole ;
    rdfs:label "has object role" ;
    rdfs:comment "Relates a coverage termination to the object participant." .

:hasManner a owl:ObjectProperty ;
    rdfs:domain :Cl_CoverageTermination ;
    rdfs:range :Cl_TemporalExtent ;
    rdfs:label "has manner" ;
    rdfs:comment "Relates a coverage termination to the condition that triggers it." .

:hasReinstatementPeriod a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_TemporalExtent ;
    rdfs:label "has reinstatement period" ;
    rdfs:comment "Relates a policy to its reinstatement period." .

:hasGracePeriodDuration a owl:ObjectProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range :Cl_TemporalExtent ;
    rdfs:label "has grace period duration" ;
    rdfs:comment "Relates a policy to its grace period duration." .

### Data Properties
:hasFaceAmount a owl:DatatypeProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:decimal ;
    rdfs:label "has face amount" ;
    rdfs:comment "Represents the monetary value of the policy's death benefit." .

:hasCurrencyUnit a owl:DatatypeProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:string ;
    rdfs:label "has currency unit" ;
    rdfs:comment "Represents the currency of the face amount." .

:hasCoverageTermStart a owl:DatatypeProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:date ;
    rdfs:label "has coverage term start" ;
    rdfs:comment "Represents the start date of the coverage term." .

:hasCoverageTermEnd a owl:DatatypeProperty ;
    rdfs:domain :Cl_Policy ;
    rdfs:range xsd:date ;
    rdfs:label "has coverage term end" ;
